# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Rails master key — required to decrypt config/credentials.yml.enc on the server.
RAILS_MASTER_KEY=$(cat config/master.key)

# Docker Hub access token (Account → Security → New Access Token, Read & Write scope).
# Set in your shell or a password manager before running bin/kamal commands:
#   export KAMAL_REGISTRY_PASSWORD=dckr_pat_...
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Postgres password for the `naila` user. The same value is exposed under two
# names because Rails reads NAILA_DATABASE_PASSWORD (config/database.yml) while
# the postgis/postgis accessory reads POSTGRES_PASSWORD.
#   export NAILA_DATABASE_PASSWORD=...
NAILA_DATABASE_PASSWORD=$NAILA_DATABASE_PASSWORD
POSTGRES_PASSWORD=$NAILA_DATABASE_PASSWORD
