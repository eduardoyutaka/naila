<%# Mobile sidebar — dialog overlay, triggered by sidebar#openMobile %>
<dialog data-sidebar-target="mobileMenu"
        class="m-0 h-full max-h-full w-full max-w-80 border-0 bg-transparent p-2 backdrop:bg-black/30 open:flex"
        data-action="click->sidebar#closeOnBackdrop">
  <div class="flex h-full w-full flex-col rounded-lg shadow-lg"
       data-action="click->sidebar#stopPropagation">
    <div class="-mb-3 flex items-center justify-end px-4 pt-3 bg-zinc-900 rounded-t-lg">
      <button data-action="click->sidebar#closeMobile"
              aria-label="Fechar navegação"
              class="rounded-lg p-2 text-zinc-400 hover:bg-white/5 hover:text-white transition-colors">
        <svg class="size-5" viewBox="0 0 20 20" aria-hidden="true" fill="currentColor">
          <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/>
        </svg>
      </button>
    </div>
    <%= render "shared/admin/sidebar" %>
  </div>
</dialog>
