<%
  nav_items = [
    { label: "Painel",       path: admin_root_path,                icon: "chart-bar" },
    { label: "Estações",     path: admin_monitoring_stations_path, icon: "signal" },
    { label: "Meteorologia", path: admin_weather_path,             icon: "cloud-rain" },
    { label: "Alarmes",      path: admin_alarms_path,              icon: "adjustments-horizontal" },
    { label: "Bacias",       path: admin_river_basins_path,        icon: "map" },
    { label: "Usuários",     path: admin_users_path,               icon: "users" },
  ]
%>

<div class="flex h-full flex-col">
  <%= catalyst_sidebar do %>

    <%# ── Header: Brand ── %>
    <%= catalyst_sidebar_header do %>
      <%= catalyst_sidebar_section do %>
        <%= link_to admin_root_path, class: "flex items-center gap-3 rounded-lg px-2 py-2" do %>
          <%# Logo mark — mix-blend-mode:screen makes the black bg transparent on dark sidebar %>
          <div class="size-10 shrink-0 overflow-hidden relative">
            <%= image_tag "logo.jpeg",
                  alt: "Naila",
                  class: "absolute w-10",
                  style: "mix-blend-mode: screen; top: 6px;" %>
          </div>
          <div class="min-w-0">
            <div class="text-sm font-bold tracking-widest text-white">NAILA</div>
            <div class="text-xs font-medium tracking-widest text-zinc-300 uppercase">Tecnologia Ambiental</div>
          </div>
        <% end %>
      <% end %>
    <% end %>

    <%# ── Body: Navigation ── %>
    <%= catalyst_sidebar_body do %>
      <%= catalyst_sidebar_section do %>
        <% nav_items.each do |item| %>
          <%= catalyst_sidebar_item item[:label],
                href: item[:path],
                current: current_page?(item[:path]) %>
        <% end %>
      <% end %>

      <%# System status %>
      <%= catalyst_sidebar_section do %>
        <%= catalyst_sidebar_heading "Status do Sistema" %>
        <div class="mt-1 rounded-lg bg-zinc-800 px-3 py-2.5 ring-1 ring-white/5">
          <div class="space-y-2">
            <div class="flex items-center justify-between text-xs">
              <span class="text-zinc-300">Sensores Online</span>
              <span class="tabular-nums font-medium text-sensor-online"><%= MonitoringStation.online.count %></span>
            </div>
            <div class="flex items-center justify-between text-xs">
              <span class="text-zinc-300">Bacias em Risco</span>
              <span class="tabular-nums font-medium text-risk-attention"><%= RiverBasin.at_risk.count %></span>
            </div>
            <div class="flex items-center justify-between text-xs">
              <span class="text-zinc-300">Alarmes Ativos</span>
              <span class="tabular-nums font-medium text-risk-high"><%= Alarm.in_alarm.count %></span>
            </div>
          </div>
        </div>
      <% end %>

      <%= catalyst_sidebar_spacer %>
    <% end %>

    <%# ── Footer: User ── %>
    <% if current_user %>
      <%= catalyst_sidebar_footer do %>
        <%= catalyst_sidebar_section do %>
          <div class="flex items-center gap-3 rounded-lg px-2 py-2.5">
            <%= catalyst_avatar initials: current_user.name.split.map(&:first).join.upcase[0..1], class: "size-8 shrink-0" %>
            <div class="min-w-0 flex-1">
              <div class="truncate text-sm/5 font-medium text-white"><%= current_user.name %></div>
              <div class="truncate text-xs/5 text-zinc-300"><%= current_user.email_address %></div>
            </div>
            <%= button_to logout_path, method: :delete,
                  form: { class: "flex items-center" },
                  class: "shrink-0 rounded-md p-1 text-zinc-400 hover:bg-white/5 hover:text-white transition-colors",
                  title: "Sair" do %>
              <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
              </svg>
            <% end %>
          </div>
        <% end %>
      <% end %>
    <% end %>

  <% end %>
</div>
