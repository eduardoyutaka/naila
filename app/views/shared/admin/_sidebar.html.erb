<%
  nav_items = [
    { label: "Painel",    path: admin_root_path,         icon: "chart-bar" },
    { label: "Estações",  path: admin_monitoring_stations_path, icon: "signal" },
    { label: "Meteorologia", path: admin_weather_path,   icon: "cloud-rain" },
    { label: "Alarmes",   path: admin_alarms_path,       icon: "adjustments-horizontal" },
    { label: "Bacias",    path: admin_river_basins_path,  icon: "map" },
    { label: "Usuários",  path: admin_users_path,        icon: "users" },
  ]
%>

<nav data-controller="sidebar"
     class="hidden lg:flex w-56 flex-col border-r border-white/10 bg-zinc-900"
     data-sidebar-target="menu">
  <div class="flex flex-1 flex-col gap-1 p-3">
    <% nav_items.each do |item| %>
      <%= link_to item[:path],
            class: "flex items-center gap-3 rounded-lg py-2.5 text-sm font-medium transition-colors
              #{current_page?(item[:path]) ?
                'border-l-2 border-sky-500 bg-sky-500/10 text-sky-500 pl-[10px] pr-3' :
                'px-3 text-zinc-400 hover:bg-zinc-800 hover:text-white'}" do %>
        <%= render "shared/icons/#{item[:icon]}" %>
        <span><%= item[:label] %></span>
      <% end %>
    <% end %>
  </div>

  <%# Bottom section: system status %>
  <div class="border-t border-white/10 p-3">
    <div class="rounded-lg bg-zinc-800 p-3">
      <div class="mb-2 text-xs font-medium uppercase tracking-wider text-zinc-400">Status do Sistema</div>
      <div class="space-y-1.5">
        <div class="flex items-center justify-between text-xs">
          <span class="text-zinc-400">Sensores Online</span>
          <span class="tabular-nums text-sensor-online"><%= MonitoringStation.online.count %></span>
        </div>
        <div class="flex items-center justify-between text-xs">
          <span class="text-zinc-400">Bacias em Risco</span>
          <span class="tabular-nums text-risk-attention"><%= RiverBasin.at_risk.count %></span>
        </div>
        <div class="flex items-center justify-between text-xs">
          <span class="text-zinc-400">Alarmes Ativos</span>
          <span class="tabular-nums text-risk-high"><%= Alarm.in_alarm.count %></span>
        </div>
      </div>
    </div>
  </div>
</nav>
