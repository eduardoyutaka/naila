<header class="sticky top-0 z-50 flex h-14 items-center justify-between border-b border-white/10 bg-zinc-950 px-4 topbar-glow">
  <div class="flex items-center gap-4">
    <%# Sidebar toggle for mobile %>
    <button data-action="click->sidebar#toggle" class="lg:hidden rounded-md p-1.5 text-zinc-400 hover:bg-zinc-800 hover:text-white">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>

    <%# Logo %>
    <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
      <span class="text-lg font-bold tracking-widest text-sky-500" style="text-shadow: 0 0 18px #0ea5e960;">NAILA</span>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <%# User menu %>
    <% if current_user %>
      <div class="flex items-center gap-2 text-sm text-zinc-400">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-zinc-800 text-xs font-medium text-white ring-1 ring-sky-500/20">
          <%= current_user.name.split.map(&:first).join.upcase[0..1] %>
        </div>
        <span class="hidden sm:inline"><%= current_user.name %></span>
      </div>
      <%= button_to logout_path, method: :delete,
            form: { class: "flex items-center" },
            class: "rounded-md p-1.5 text-zinc-400 hover:bg-zinc-800 hover:text-white transition-colors",
            title: "Sair" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
        </svg>
      <% end %>
    <% end %>
  </div>
</header>
