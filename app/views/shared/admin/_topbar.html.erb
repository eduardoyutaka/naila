<header class="sticky top-0 z-50 flex h-14 items-center justify-between border-b border-naila-border bg-naila-surface px-4">
  <div class="flex items-center gap-4">
    <%# Sidebar toggle for mobile %>
    <button data-action="click->sidebar#toggle" class="lg:hidden rounded-md p-1.5 text-naila-text-muted hover:bg-naila-elevated hover:text-naila-text">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </button>

    <%# Logo %>
    <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
      <span class="text-lg font-bold tracking-tight text-naila-accent">NAILA</span>
    <% end %>
  </div>

  <div class="flex items-center gap-3">
    <%# Active alerts indicator %>
    <% active_alert_count = Alert.active.count %>
    <% highest_severity = Alert.active.maximum(:severity) %>
    <% if active_alert_count > 0 %>
      <div class="flex items-center gap-2 rounded-lg border px-3 py-1.5 text-sm font-medium
        <%= case highest_severity
            when 4 then 'border-risk-emergency/40 bg-risk-emergency/10 text-risk-emergency glow-emergency'
            when 3 then 'border-risk-high/40 bg-risk-high/10 text-risk-high glow-high'
            when 2 then 'border-risk-alert/40 bg-risk-alert/10 text-risk-alert glow-alert'
            else 'border-risk-attention/40 bg-risk-attention/10 text-risk-attention glow-attention'
            end %>">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
        </svg>
        <span class="tabular-nums"><%= active_alert_count %></span>
      </div>
    <% end %>

    <%# User menu %>
    <% if current_user %>
      <div class="flex items-center gap-2 text-sm text-naila-text-muted">
        <div class="flex h-8 w-8 items-center justify-center rounded-full bg-naila-elevated text-xs font-medium text-naila-text">
          <%= current_user.name.split.map(&:first).join.upcase[0..1] %>
        </div>
        <span class="hidden sm:inline"><%= current_user.name %></span>
      </div>
      <%= button_to logout_path, method: :delete,
            form: { class: "flex items-center" },
            class: "rounded-md p-1.5 text-naila-text-muted hover:bg-naila-elevated hover:text-naila-text transition-colors",
            title: "Sair" do %>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
        </svg>
      <% end %>
    <% end %>
  </div>
</header>
