<header class="sticky top-0 z-50 border-b border-gray-200 bg-white">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4">
    <%= link_to root_path, class: "flex items-center gap-2" do %>
      <span class="text-xl font-bold tracking-tight text-blue-700">NAILA</span>
      <span class="hidden text-sm text-gray-500 sm:inline">Monitoramento de Cheias</span>
    <% end %>

    <nav class="flex items-center gap-1">
      <%
        public_nav = [
          { label: "Mapa", path: risk_map_path },
          { label: "Alarmes", path: public_alarms_path },
          { label: "Bairros", path: neighborhoods_path },
          { label: "Segurança", path: safety_path },
        ]
      %>
      <% public_nav.each do |item| %>
        <%= link_to item[:label], item[:path],
              class: "rounded-lg px-3 py-2 text-sm font-medium transition-colors
                #{current_page?(item[:path]) ?
                  'bg-blue-700/10 text-blue-700' :
                  'text-gray-600 hover:bg-gray-100 hover:text-gray-900'}" %>
      <% end %>
    </nav>
  </div>
</header>
