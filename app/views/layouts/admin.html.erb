<!DOCTYPE html>
<html lang="pt-BR" class="dark">
  <head>
    <title><%= content_for(:title) || "Naila — Painel" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Naila">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ol@10.5.0/ol.css">
    <script src="https://cdn.jsdelivr.net/npm/ol@10.5.0/dist/ol.js"></script>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-zinc-950 text-white font-sans antialiased">
    <div class="relative isolate flex min-h-svh w-full max-lg:flex-col lg:bg-zinc-950"
         data-controller="sidebar">

      <%# ── Desktop Sidebar ── %>
      <div class="fixed inset-y-0 left-0 w-64 max-lg:hidden">
        <%= render "shared/admin/sidebar" %>
      </div>

      <%# ── Mobile Header ── %>
      <header class="flex items-center gap-2 px-4 lg:hidden border-b border-white/10 bg-zinc-900">
        <div class="py-2.5">
          <button data-action="click->sidebar#openMobile"
                  aria-label="Abrir navegação"
                  class="rounded-lg p-2 text-zinc-400 hover:bg-white/5 hover:text-white transition-colors">
            <svg class="size-5" data-slot="icon" viewBox="0 0 20 20" aria-hidden="true" fill="currentColor">
              <path d="M2 6.75C2 6.33579 2.33579 6 2.75 6H17.25C17.6642 6 18 6.33579 18 6.75C18 7.16421 17.6642 7.5 17.25 7.5H2.75C2.33579 7.5 2 7.16421 2 6.75ZM2 13.25C2 12.8358 2.33579 12.5 2.75 12.5H17.25C17.6642 12.5 18 12.8358 18 13.25C18 13.6642 17.6642 14 17.25 14H2.75C2.33579 14 2 13.6642 2 13.25Z"/>
            </svg>
          </button>
        </div>
        <div class="min-w-0 flex-1 flex items-center gap-2 py-1.5">
          <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
            <%= image_tag "logo5.jpeg",
                  alt: "Naila",
                  class: "size-8 object-contain shrink-0",
                  style: "mix-blend-mode: screen;" %>
            <span class="text-sm font-bold tracking-widest text-white">NAILA</span>
          <% end %>
        </div>
      </header>

      <%# ── Mobile Sidebar Overlay ── %>
      <%= render "shared/admin/mobile_sidebar" %>

      <%# ── Main Content ── %>
      <main class="flex flex-1 flex-col pb-2 lg:min-w-0 lg:pt-2 lg:pr-2 lg:pl-64">
        <div class="grow p-6 lg:rounded-lg lg:bg-zinc-900 lg:p-10 lg:shadow-xs lg:ring-1 lg:ring-white/10">
          <div class="mx-auto max-w-6xl">
            <% if notice %>
              <div class="mb-6 rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-3 text-green-400 animate-fade-in">
                <%= notice %>
              </div>
            <% end %>
            <% if alert %>
              <div class="mb-6 rounded-lg border border-risk-high/30 bg-risk-high/10 px-4 py-3 text-risk-high animate-fade-in">
                <%= alert %>
              </div>
            <% end %>

            <%= yield %>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
