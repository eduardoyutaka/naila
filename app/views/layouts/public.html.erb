<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Naila — Monitoramento de Cheias de Curitiba" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Sistema de monitoramento de risco de enchentes da cidade de Curitiba. Consulte o nivel de risco do seu bairro em tempo real.">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Naila">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-public-bg text-public-text font-sans antialiased">
    <%= render "shared/public/navbar" %>

    <main>
      <% if notice %>
        <div class="mx-auto max-w-7xl px-4 pt-4">
          <div class="rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-green-800 animate-fade-in">
            <%= notice %>
          </div>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%= render "shared/public/footer" %>
  </body>
</html>
