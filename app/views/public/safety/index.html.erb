<% content_for(:title, "Segurança — Naila") %>

<div class="mx-auto max-w-7xl px-4 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-zinc-950">Segurança em Enchentes</h1>
    <p class="mt-1 text-gray-600">Rotas de evacuação e orientações para situações de risco.</p>
  </div>

  <%# ── Evacuation Routes ── %>
  <section class="mb-10">
    <h2 class="mb-4 text-lg font-semibold text-zinc-950">Rotas de Evacuação</h2>
    <% if @evacuation_routes.empty? %>
      <div class="rounded-xl border border-gray-200 bg-gray-50 px-6 py-10 text-center">
        <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
        </svg>
        <p class="mt-3 text-sm font-medium text-gray-600">Nenhuma rota de evacuação cadastrada.</p>
        <p class="mt-1 text-sm text-gray-500">Entre em contato com a Defesa Civil para mais informações.</p>
      </div>
    <% else %>
      <div class="space-y-4">
        <% @evacuation_routes.each do |route| %>
          <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="min-w-0">
                <h3 class="font-semibold text-zinc-950"><%= route.name %></h3>
                <% if route.river_basin %>
                  <p class="mt-0.5 text-sm text-gray-500">Bacia: <%= route.river_basin.name %></p>
                <% end %>
                <% if route.description.present? %>
                  <p class="mt-2 text-sm text-gray-600"><%= route.description %></p>
                <% end %>
                <% if route.destination_name.present? %>
                  <div class="mt-2 flex items-center gap-1 text-sm text-gray-500">
                    <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                    </svg>
                    Destino: <%= route.destination_name %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </section>

  <%# ── Safety Guidelines ── %>
  <section>
    <h2 class="mb-4 text-lg font-semibold text-zinc-950">Orientações de Segurança</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-blue-200 bg-blue-50 p-5">
        <h3 class="font-semibold text-blue-900">Antes da enchente</h3>
        <ul class="mt-3 space-y-2 text-base text-blue-800">
          <li class="flex gap-2"><span class="shrink-0">•</span> Mantenha documentos em local seguro e de fácil acesso</li>
          <li class="flex gap-2"><span class="shrink-0">•</span> Tenha um kit de emergência com água, alimentos e medicamentos</li>
          <li class="flex gap-2"><span class="shrink-0">•</span> Conheça a rota de evacuação do seu bairro</li>
          <li class="flex gap-2"><span class="shrink-0">•</span> Acompanhe os alertas da Defesa Civil</li>
        </ul>
      </div>

      <div class="rounded-xl border border-orange-200 bg-orange-50 p-5">
        <h3 class="font-semibold text-orange-900">Durante a enchente</h3>
        <ul class="mt-3 space-y-2 text-base text-orange-800">
          <li class="flex gap-2"><span class="shrink-0">•</span> Não atravesse ruas alagadas a pé ou de carro</li>
          <li class="flex gap-2"><span class="shrink-0">•</span> Desligue a energia elétrica se houver risco de inundação</li>
          <li class="flex gap-2"><span class="shrink-0">•</span> Vá para lugares altos e aguarde orientações</li>
          <li class="flex gap-2"><span class="shrink-0">•</span> Ligue 199 (Defesa Civil) ou 193 (Bombeiros) em emergência</li>
        </ul>
      </div>

      <div class="rounded-xl border border-green-200 bg-green-50 p-5">
        <h3 class="font-semibold text-green-900">Após a enchente</h3>
        <ul class="mt-3 space-y-2 text-base text-green-800">
          <li class="flex gap-2"><span class="shrink-0">•</span> Só retorne quando as autoridades liberarem</li>
          <li class="flex gap-2"><span class="shrink-0">•</span> Use botas e luvas ao limpar o local</li>
          <li class="flex gap-2"><span class="shrink-0">•</span> Não consuma água da torneira sem verificar se está liberada</li>
          <li class="flex gap-2"><span class="shrink-0">•</span> Fotografe os danos para fins de seguro e assistência</li>
        </ul>
      </div>

      <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
        <h3 class="font-semibold text-zinc-950">Contatos de emergência</h3>
        <ul class="mt-3 space-y-2 text-sm text-gray-700">
          <li class="flex items-center justify-between">
            <span>Defesa Civil</span>
            <span class="font-semibold tabular-nums text-zinc-950">199</span>
          </li>
          <li class="flex items-center justify-between">
            <span>Corpo de Bombeiros</span>
            <span class="font-semibold tabular-nums text-zinc-950">193</span>
          </li>
          <li class="flex items-center justify-between">
            <span>SAMU</span>
            <span class="font-semibold tabular-nums text-zinc-950">192</span>
          </li>
          <li class="flex items-center justify-between">
            <span>Polícia Militar</span>
            <span class="font-semibold tabular-nums text-zinc-950">190</span>
          </li>
        </ul>
      </div>
    </div>
  </section>
</div>
