<% content_for(:title, "Alertas — Naila") %>

<div class="mx-auto max-w-7xl px-4 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-public-text">Alertas de Risco</h1>
    <p class="mt-1 text-gray-600">Acompanhe os alertas ativos e recentes de risco de enchentes em Curitiba.</p>
  </div>

  <%# ── Active Alerts ── %>
  <div data-testid="active-alerts">
    <% if @active_alerts.empty? %>
      <div class="rounded-xl border border-green-200 bg-green-50 px-6 py-8 text-center">
        <svg class="mx-auto h-10 w-10 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <p class="mt-3 text-lg font-semibold text-green-800">Nenhum alerta ativo no momento</p>
        <p class="mt-1 text-sm text-green-700">A situação está normal. Continue acompanhando para atualizações.</p>
      </div>
    <% else %>
      <div class="space-y-4">
        <% @active_alerts.each do |alert| %>
          <%
            severity_border = case alert.severity
                              when 4 then "border-l-risk-emergency"
                              when 3 then "border-l-risk-high"
                              when 2 then "border-l-risk-alert"
                              else "border-l-risk-attention"
                              end
            severity_classes = case alert.severity
                              when 4 then "bg-risk-emergency/10 text-risk-emergency"
                              when 3 then "bg-risk-high/10 text-risk-high"
                              when 2 then "bg-risk-alert/10 text-risk-alert"
                              else "bg-risk-attention/10 text-risk-attention"
                              end
            severity_label = case alert.severity
                             when 4 then "Emergência"
                             when 3 then "Alerta Máximo"
                             when 2 then "Alerta"
                             else "Atenção"
                             end
          %>
          <div class="rounded-xl border border-gray-200 border-l-4 bg-white p-5 shadow-sm <%= severity_border %>" data-testid="alert-card">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-semibold <%= severity_classes %>" data-testid="alert-severity">
                <%= severity_label %>
              </span>
              <span class="text-xs text-gray-500"><%= time_ago_in_words(alert.activated_at || alert.created_at) %> atrás</span>
            </div>

            <h2 class="text-lg font-semibold text-gray-900"><%= alert.title %></h2>
            <p class="mt-1 text-sm text-gray-600"><%= alert.description %></p>

            <% if alert.instructions.present? %>
              <div class="mt-3 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
                <div class="text-xs font-semibold uppercase tracking-wider text-amber-700 mb-1">Instruções</div>
                <p class="text-sm text-amber-900"><%= alert.instructions %></p>
              </div>
            <% end %>

            <% location = [alert.neighborhood&.name, alert.risk_zone&.name].compact %>
            <% if location.any? %>
              <div class="mt-3 flex items-center gap-1 text-xs text-gray-500">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                <%= location.join(" · ") %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ── Recently Resolved ── %>
  <div class="mt-10" data-testid="resolved-alerts">
    <h2 class="mb-4 text-lg font-semibold text-gray-900">Alertas Recentes Resolvidos</h2>

    <% if @recent_resolved.empty? %>
      <p class="text-sm text-gray-500">Nenhum alerta resolvido recentemente.</p>
    <% else %>
      <div class="rounded-xl border border-gray-200 bg-white shadow-sm">
        <div class="divide-y divide-gray-100">
          <% @recent_resolved.each do |alert| %>
            <%
              severity_classes = case alert.severity
                                when 4 then "bg-gray-200 text-gray-600"
                                when 3 then "bg-gray-200 text-gray-600"
                                when 2 then "bg-gray-100 text-gray-500"
                                else "bg-gray-100 text-gray-500"
                                end
              severity_label = case alert.severity
                               when 4 then "Emergência"
                               when 3 then "Alerta Máximo"
                               when 2 then "Alerta"
                               else "Atenção"
                               end
            %>
            <div class="flex items-center justify-between px-4 py-3">
              <div class="flex items-center gap-3 min-w-0">
                <span class="inline-flex flex-shrink-0 rounded-full px-2 py-0.5 text-xs font-medium <%= severity_classes %>">
                  <%= severity_label %>
                </span>
                <span class="text-sm text-gray-700 truncate"><%= alert.title %></span>
              </div>
              <span class="flex-shrink-0 text-xs tabular-nums text-gray-400 ml-3">
                <%= alert.resolved_at&.strftime("%d/%m %H:%M") %>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
