<% content_for(:title, "#{@neighborhood.name} — Naila") %>

<div class="mx-auto max-w-7xl px-4 py-8">
  <%# ── Back link ── %>
  <%= link_to neighborhoods_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-6" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
    </svg>
    Bairros
  <% end %>

  <%# ── Header ── %>
  <div class="mb-6 flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-zinc-950"><%= @neighborhood.name %></h1>
      <% if @neighborhood.region %>
        <p class="mt-1 text-gray-500"><%= @neighborhood.region.name %></p>
      <% end %>
    </div>
    <%= risk_level_badge(@neighborhood.current_risk_level) %>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <%# ── Info Cards ── %>
    <div class="lg:col-span-2 space-y-6">
      <%# Details ── %>
      <div class="rounded-xl border border-gray-200 bg-white shadow-sm">
        <div class="border-b border-gray-100 px-4 py-3">
          <h2 class="text-sm font-semibold text-zinc-950">Informações</h2>
        </div>
        <div class="divide-y divide-gray-100">
          <% if @neighborhood.population %>
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-sm text-gray-500">População</span>
              <span class="text-sm font-medium text-zinc-950"><%= number_with_delimiter(@neighborhood.population) %> hab.</span>
            </div>
          <% end %>
          <% if @neighborhood.area_km2 %>
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-sm text-gray-500">Área</span>
              <span class="text-sm font-medium text-zinc-950"><%= number_with_precision(@neighborhood.area_km2, precision: 2) %> km²</span>
            </div>
          <% end %>
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-sm text-gray-500">Código</span>
            <span class="text-sm font-mono text-zinc-950"><%= @neighborhood.code %></span>
          </div>
        </div>
      </div>

      <%# Monitoring Stations ── %>
      <% if @nearby_stations.any? %>
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-100 px-4 py-3">
            <h2 class="text-sm font-semibold text-zinc-950">Estações de Monitoramento</h2>
          </div>
          <div class="divide-y divide-gray-100">
            <% @nearby_stations.each do |station| %>
              <div class="px-4 py-3">
                <div class="flex items-center justify-between">
                  <span class="text-sm font-medium text-zinc-950"><%= station.name %></span>
                  <%
                    status_label = { "active" => "Online", "maintenance" => "Manutenção", "inactive" => "Inativo" }[station.status] || station.status
                    status_class = { "active" => "text-green-600", "maintenance" => "text-yellow-600", "inactive" => "text-red-600" }[station.status] || "text-gray-500"
                  %>
                  <span class="text-xs font-medium <%= status_class %>"><%= status_label %></span>
                </div>
                <% if station.sensors.any? %>
                  <div class="mt-1 flex flex-wrap gap-1">
                    <% station.sensors.each do |sensor| %>
                      <%= sensor_type_badge(sensor.sensor_type) %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# ── City Risk Sidebar ── %>
    <div>
      <% if @active_river_basins.any? %>
        <div class="rounded-xl border border-orange-200 bg-orange-50 p-4">
          <h2 class="text-sm font-semibold text-orange-900 mb-3">Bacias em Risco</h2>
          <div class="space-y-2">
            <% @active_river_basins.each do |basin| %>
              <div class="flex items-center justify-between">
                <span class="text-sm text-orange-800 truncate mr-2"><%= basin.name %></span>
                <%= risk_level_badge(basin.current_risk_level) %>
              </div>
            <% end %>
          </div>
          <div class="mt-4">
            <%= link_to "Ver mapa de risco", risk_map_path, class: "text-sm font-medium text-orange-700 hover:text-orange-900" %>
          </div>
        </div>
      <% else %>
        <div class="rounded-xl border border-green-200 bg-green-50 p-4">
          <p class="text-sm font-medium text-green-800">Nenhuma bacia em risco elevado no momento.</p>
          <div class="mt-3">
            <%= link_to "Ver mapa de risco", risk_map_path, class: "text-sm font-medium text-green-700 hover:text-green-900" %>
          </div>
        </div>
      <% end %>

      <div class="mt-4">
        <%= link_to public_alarms_path, class: "block rounded-xl border border-gray-200 bg-white p-4 shadow-sm hover:border-blue-300 transition-colors text-sm font-medium text-zinc-950" do %>
          Ver alarmes ativos
          <svg class="inline h-4 w-4 ml-1 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</div>
