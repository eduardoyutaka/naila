<% content_for(:title, "Bairros — Naila") %>

<div class="mx-auto max-w-7xl px-4 py-8">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-zinc-950">Bairros de Curitiba</h1>
    <p class="mt-1 text-gray-600">Consulte o nível de risco de enchente por bairro.</p>
  </div>

  <%# ── Risk Summary ── %>
  <%
    at_risk = @neighborhoods.reject { |n| n.risk_normal? }
    at_risk_count = at_risk.size
  %>
  <% if at_risk_count > 0 %>
    <div class="mb-6 rounded-xl border border-orange-200 bg-orange-50 px-4 py-3">
      <p class="text-sm font-medium text-orange-800">
        <%= at_risk_count %> <%= at_risk_count == 1 ? "bairro" : "bairros" %> com risco elevado no momento.
      </p>
    </div>
  <% else %>
    <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-4 py-3">
      <p class="text-sm font-medium text-green-800">Todos os bairros em situação normal.</p>
    </div>
  <% end %>

  <%# ── Neighborhoods Grid ── %>
  <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
    <% @neighborhoods.each do |neighborhood| %>
      <%= link_to neighborhood_path(neighborhood.code), class: "group rounded-xl border border-gray-200 bg-white p-4 shadow-sm hover:border-blue-300 hover:shadow-md transition-all" do %>
        <div class="flex items-start justify-between gap-2">
          <div class="min-w-0">
            <h2 class="font-semibold text-zinc-950 group-hover:text-blue-700 transition-colors truncate">
              <%= neighborhood.name %>
            </h2>
            <% if neighborhood.region %>
              <p class="mt-0.5 text-xs text-gray-500"><%= neighborhood.region.name %></p>
            <% end %>
            <% if neighborhood.population %>
              <p class="mt-1 text-xs text-gray-400"><%= number_with_delimiter(neighborhood.population) %> hab.</p>
            <% end %>
          </div>
          <div class="shrink-0 mt-0.5">
            <%= risk_level_badge(neighborhood.current_risk_level) %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if @neighborhoods.empty? %>
    <div class="py-12 text-center">
      <p class="text-sm text-gray-500">Nenhum bairro cadastrado.</p>
    </div>
  <% end %>
</div>
