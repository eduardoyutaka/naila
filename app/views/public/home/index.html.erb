<% content_for(:title, "Naila — Monitoramento de Cheias de Curitiba") %>

<%
  risk_labels = { 0 => "Normal", 1 => "Atenção", 2 => "Alerta", 3 => "Alerta Máximo", 4 => "Emergência" }
  risk_bg = {
    0 => "bg-green-50 border-green-200",
    1 => "bg-yellow-50 border-yellow-200",
    2 => "bg-orange-50 border-orange-200",
    3 => "bg-red-50 border-red-200",
    4 => "bg-red-950 border-red-900",
  }
  risk_text = {
    0 => "text-green-800",
    1 => "text-yellow-800",
    2 => "text-orange-800",
    3 => "text-red-800",
    4 => "text-red-100",
  }
  risk_sub = {
    0 => "text-green-700",
    1 => "text-yellow-700",
    2 => "text-orange-700",
    3 => "text-red-700",
    4 => "text-red-300",
  }
  level = @city_risk_level.to_i
%>

<%# ── City Status Banner ── %>
<div class="border-b <%= risk_bg[level] %>">
  <div class="mx-auto max-w-7xl px-4 py-10 text-center">
    <p class="text-sm font-semibold uppercase tracking-wider <%= risk_sub[level] %>">Nível de Risco da Cidade</p>
    <h1 class="mt-2 text-4xl font-bold <%= risk_text[level] %>"><%= risk_labels[level] %></h1>
    <p class="mt-3 text-base <%= risk_sub[level] %>">
      <% if level == 0 %>
        Curitiba está em situação normal. Sem enchentes previstas.
      <% else %>
        <%= @basins_at_risk_count %> <%= @basins_at_risk_count == 1 ? "bacia hidrográfica" : "bacias hidrográficas" %> em situação elevada de risco.
      <% end %>
    </p>
  </div>
</div>

<div class="mx-auto max-w-7xl px-4 py-8">
  <%# ── Quick Stats ── %>
  <div class="mb-10 grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="rounded-xl border border-gray-200 bg-white p-5 text-center shadow-sm">
      <div class="text-3xl font-bold tabular-nums text-zinc-950"><%= @active_alarms_count %></div>
      <div class="mt-1 text-sm font-medium text-gray-500">Alarmes Ativos</div>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5 text-center shadow-sm">
      <div class="text-3xl font-bold tabular-nums text-zinc-950"><%= @basins_at_risk_count %></div>
      <div class="mt-1 text-sm font-medium text-gray-500">Bacias em Risco</div>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5 text-center shadow-sm">
      <div class="text-3xl font-bold tabular-nums text-zinc-950"><%= RiverBasin.active.count %></div>
      <div class="mt-1 text-sm font-medium text-gray-500">Bacias Monitoradas</div>
    </div>
  </div>

  <%# ── Highest Alarm ── %>
  <% if @highest_alarm %>
    <div class="mb-10 rounded-xl border border-orange-200 bg-orange-50 p-5">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-orange-600">Alarme mais severo</p>
          <h2 class="mt-1 text-lg font-semibold text-orange-900"><%= @highest_alarm.name %></h2>
          <% if @highest_alarm.state_reason.present? %>
            <p class="mt-1 text-sm text-orange-700"><%= @highest_alarm.state_reason %></p>
          <% end %>
        </div>
        <%= link_to public_alarms_path, class: "shrink-0 rounded-lg border border-orange-300 bg-white px-4 py-2 text-sm font-medium text-orange-700 hover:bg-orange-100 transition-colors" do %>
          Ver todos os alarmes
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Quick Links ── %>
  <h2 class="mb-4 text-lg font-semibold text-zinc-950">Acesse</h2>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <%= link_to risk_map_path, class: "group rounded-xl border border-gray-200 bg-white p-5 shadow-sm hover:border-blue-300 hover:shadow-md transition-all" do %>
      <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-blue-50 text-blue-600 group-hover:bg-blue-100">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
        </svg>
      </div>
      <h3 class="font-semibold text-zinc-950">Mapa de Risco</h3>
      <p class="mt-1 text-sm text-gray-500">Visualize o risco por bacia hidrográfica</p>
    <% end %>

    <%= link_to public_alarms_path, class: "group rounded-xl border border-gray-200 bg-white p-5 shadow-sm hover:border-blue-300 hover:shadow-md transition-all" do %>
      <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-red-50 text-red-600 group-hover:bg-red-100">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
        </svg>
      </div>
      <h3 class="font-semibold text-zinc-950">Alarmes</h3>
      <p class="mt-1 text-sm text-gray-500">Alertas ativos e histórico recente</p>
    <% end %>

    <%= link_to neighborhoods_path, class: "group rounded-xl border border-gray-200 bg-white p-5 shadow-sm hover:border-blue-300 hover:shadow-md transition-all" do %>
      <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-100 text-zinc-600 group-hover:bg-zinc-200">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12 11.204 3.045c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
      </div>
      <h3 class="font-semibold text-zinc-950">Bairros</h3>
      <p class="mt-1 text-sm text-gray-500">Consulte o risco no seu bairro</p>
    <% end %>

    <%= link_to safety_path, class: "group rounded-xl border border-gray-200 bg-white p-5 shadow-sm hover:border-blue-300 hover:shadow-md transition-all" do %>
      <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-green-50 text-green-600 group-hover:bg-green-100">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
        </svg>
      </div>
      <h3 class="font-semibold text-zinc-950">Segurança</h3>
      <p class="mt-1 text-sm text-gray-500">Rotas de evacuação e orientações</p>
    <% end %>
  </div>
</div>
