<% content_for(:title, "Naila — Alerta: #{@alert.title}") %>

<%
  severity_classes = case @alert.severity
                     when 4 then "bg-risk-emergency/20 text-risk-emergency"
                     when 3 then "bg-risk-high/20 text-risk-high"
                     when 2 then "bg-risk-alert/20 text-risk-alert"
                     else "bg-risk-attention/20 text-risk-attention"
                     end
  severity_label = case @alert.severity
                   when 4 then "Emergência"
                   when 3 then "Alerta Máximo"
                   when 2 then "Alerta"
                   else "Atenção"
                   end
  status_classes = case @alert.status
                   when "active" then "bg-risk-high/20 text-risk-high"
                   when "acknowledged" then "bg-risk-attention/20 text-risk-attention"
                   when "resolved" then "bg-risk-normal/20 text-risk-normal"
                   end
  status_label = case @alert.status
                 when "active" then "Ativo"
                 when "acknowledged" then "Reconhecido"
                 when "resolved" then "Resolvido"
                 end
%>

<%# ── Back Link ── %>
<div class="mb-4">
  <%= link_to admin_alerts_path, class: "inline-flex items-center gap-1 text-sm text-naila-text-muted hover:text-naila-accent transition-colors" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
    </svg>
    Voltar aos alertas
  <% end %>
</div>

<%# ── Header ── %>
<div class="mb-6">
  <div class="flex flex-wrap items-center gap-2 mb-2">
    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= severity_classes %>"><%= severity_label %></span>
    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= status_classes %>"><%= status_label %></span>
    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium bg-naila-elevated text-naila-text-muted">
      <%= @alert.alert_type == "automatic" ? "Automático" : "Manual" %>
    </span>
  </div>
  <h1 class="text-xl font-semibold text-naila-text"><%= @alert.title %></h1>
</div>

<div class="grid gap-6 lg:grid-cols-3">
  <%# ── Left Column (Details) ── %>
  <div class="lg:col-span-2 space-y-6">
    <%# Description & Instructions %>
    <div class="rounded-xl border border-naila-border bg-naila-surface">
      <div class="border-b border-naila-border px-4 py-3">
        <h2 class="text-sm font-semibold text-naila-text">Detalhes</h2>
      </div>
      <div class="p-4 space-y-4">
        <p class="text-sm text-naila-text"><%= @alert.description %></p>

        <% if @alert.instructions.present? %>
          <div class="rounded-lg border border-risk-attention/30 bg-risk-attention/10 px-4 py-3" data-testid="alert-instructions">
            <div class="text-xs font-medium uppercase tracking-wider text-risk-attention mb-1">Instruções para a população</div>
            <p class="text-sm text-naila-text"><%= @alert.instructions %></p>
          </div>
        <% end %>
      </div>
    </div>

    <%# Location & Context %>
    <% if @alert.river_basin || @alert.neighborhood || @alert.river %>
      <div class="rounded-xl border border-naila-border bg-naila-surface">
        <div class="border-b border-naila-border px-4 py-3">
          <h2 class="text-sm font-semibold text-naila-text">Localização e Contexto</h2>
        </div>
        <div class="divide-y divide-naila-border">
          <% if @alert.river_basin %>
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Bacia Hidrográfica</span>
              <span class="text-sm text-naila-text"><%= @alert.river_basin.name %></span>
            </div>
          <% end %>
          <% if @alert.neighborhood %>
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Bairro</span>
              <span class="text-sm text-naila-text"><%= @alert.neighborhood.name %></span>
            </div>
          <% end %>
          <% if @alert.river %>
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Rio</span>
              <span class="text-sm text-naila-text"><%= @alert.river.name %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Timeline %>
    <div class="rounded-xl border border-naila-border bg-naila-surface">
      <div class="border-b border-naila-border px-4 py-3">
        <h2 class="text-sm font-semibold text-naila-text">Linha do Tempo</h2>
      </div>
      <div class="p-4">
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <div class="mt-1 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-risk-high"></div>
            <div>
              <div class="text-sm font-medium text-naila-text">Ativado</div>
              <div class="text-xs text-naila-text-muted">
                <%= (@alert.activated_at || @alert.created_at).strftime("%d/%m/%Y %H:%M") %>
                · <%= time_ago_in_words(@alert.activated_at || @alert.created_at) %> atrás
              </div>
            </div>
          </div>

          <% if @alert.acknowledged_at %>
            <div class="flex items-start gap-3">
              <div class="mt-1 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-risk-attention"></div>
              <div>
                <div class="text-sm font-medium text-naila-text">Reconhecido</div>
                <div class="text-xs text-naila-text-muted">
                  <%= @alert.acknowledged_at.strftime("%d/%m/%Y %H:%M") %>
                  · <%= time_ago_in_words(@alert.acknowledged_at) %> atrás
                </div>
              </div>
            </div>
          <% end %>

          <% if @alert.resolved_at %>
            <div class="flex items-start gap-3">
              <div class="mt-1 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-risk-normal"></div>
              <div>
                <div class="text-sm font-medium text-naila-text">Resolvido</div>
                <div class="text-xs text-naila-text-muted">
                  <%= @alert.resolved_at.strftime("%d/%m/%Y %H:%M") %>
                  · <%= time_ago_in_words(@alert.resolved_at) %> atrás
                  <% if @alert.resolved_by %>
                    · por <%= @alert.resolved_by.name %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Alert Thresholds %>
    <% if @thresholds.any? %>
      <%
        parameter_labels = { "precipitation" => "Precipitação", "precipitation_1h" => "Precipitação 1h", "precipitation_3h" => "Precipitação 3h", "river_level" => "Nível do Rio" }
        comparison_labels = { "gt" => ">", "gte" => "≥", "lt" => "<", "lte" => "≤" }
      %>
      <div class="rounded-xl border border-naila-border bg-naila-surface" data-testid="thresholds-section">
        <div class="flex items-center justify-between border-b border-naila-border px-4 py-3">
          <h2 class="text-sm font-semibold text-naila-text">Limiares de Alerta</h2>
          <% if policy(AlertThreshold).create? %>
            <%= link_to new_admin_alert_threshold_path(alert_id: @alert.id, river_basin_id: @alert.river_basin_id, river_id: @alert.river_id),
                  class: "inline-flex items-center gap-1.5 rounded-lg bg-naila-accent px-3 py-2 text-xs font-medium text-white transition-colors hover:bg-naila-accent/90" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              Novo Limiar
            <% end %>
          <% end %>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-naila-border">
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Parâmetro</th>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Severidade</th>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Valor</th>
                <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Escopo</th>
                <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-naila-text-muted">Ações</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-naila-border">
              <% @thresholds.each do |threshold| %>
                <% is_trigger = threshold.id == @alert.alert_threshold_id %>
                <tr class="<%= is_trigger ? 'bg-naila-accent/5 border-l-2 border-l-naila-accent' : 'hover:bg-naila-elevated/50' %> transition-colors">
                  <td class="px-4 py-3">
                    <div class="text-sm font-medium text-naila-text"><%= parameter_labels[threshold.parameter] || threshold.parameter %></div>
                    <div class="text-xs text-naila-text-muted"><%= threshold.threshold_type %></div>
                  </td>
                  <td class="px-4 py-3">
                    <% sev_classes = case threshold.severity
                                     when 4 then "bg-risk-emergency/20 text-risk-emergency"
                                     when 3 then "bg-risk-high/20 text-risk-high"
                                     when 2 then "bg-risk-alert/20 text-risk-alert"
                                     else "bg-risk-attention/20 text-risk-attention"
                                     end %>
                    <% sev_label = case threshold.severity
                                   when 4 then "Emergência"
                                   when 3 then "Alerta Máximo"
                                   when 2 then "Alerta"
                                   else "Atenção"
                                   end %>
                    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= sev_classes %>"><%= sev_label %></span>
                  </td>
                  <td class="px-4 py-3 text-sm tabular-nums text-naila-text">
                    <%= comparison_labels[threshold.comparison] || threshold.comparison %> <%= threshold.value %> <%= threshold.unit %>
                  </td>
                  <td class="px-4 py-3 text-sm text-naila-text-muted">
                    <% if threshold.river_basin %>
                      <%= threshold.river_basin.name %>
                    <% elsif threshold.river %>
                      <%= threshold.river.name %>
                    <% else %>
                      <span class="italic">Global</span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 text-right">
                    <div class="inline-flex gap-1">
                      <% if policy(threshold).update? %>
                        <%= link_to edit_admin_alert_threshold_path(threshold, alert_id: @alert.id),
                              class: "rounded-md p-1.5 text-naila-text-muted hover:bg-naila-elevated hover:text-naila-accent transition-colors",
                              title: "Editar" do %>
                          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                          </svg>
                        <% end %>
                      <% end %>
                      <% if policy(threshold).destroy? %>
                        <%= button_to admin_alert_threshold_path(threshold, alert_id: @alert.id),
                              method: :delete,
                              class: "rounded-md p-1.5 text-naila-text-muted hover:bg-red-500/10 hover:text-red-400 transition-colors",
                              title: "Excluir",
                              form: { data: { turbo_confirm: "Tem certeza que deseja excluir este limiar?" } } do %>
                          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                          </svg>
                        <% end %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  </div>

  <%# ── Right Column (Actions + Notifications) ── %>
  <div class="space-y-6">
    <%# Actions %>
    <div class="rounded-xl border border-naila-border bg-naila-surface">
      <div class="border-b border-naila-border px-4 py-3">
        <h2 class="text-sm font-semibold text-naila-text">Ações</h2>
      </div>
      <div class="p-4 space-y-3">
        <% if @alert.status == "active" && !@alert.acknowledged? %>
          <%= button_to "Reconhecer Alerta",
                acknowledge_admin_alert_path(@alert),
                method: :patch,
                class: "w-full rounded-lg bg-risk-attention/20 px-4 py-2.5 text-sm font-medium text-risk-attention transition-colors hover:bg-risk-attention/30" %>
        <% end %>

        <% if @alert.status != "resolved" %>
          <%= button_to "Resolver Alerta",
                resolve_admin_alert_path(@alert),
                method: :patch,
                class: "w-full rounded-lg bg-risk-normal/20 px-4 py-2.5 text-sm font-medium text-risk-normal transition-colors hover:bg-risk-normal/30",
                form: { data: { turbo_confirm: "Tem certeza que deseja resolver este alerta?" } } %>
        <% end %>

        <% if @alert.resolved? %>
          <div class="text-center text-sm text-naila-text-muted py-2">
            Este alerta foi resolvido.
          </div>
        <% end %>
      </div>
    </div>

    <%# Notifications %>
    <div class="rounded-xl border border-naila-border bg-naila-surface">
      <div class="flex items-center justify-between border-b border-naila-border px-4 py-3">
        <h2 class="text-sm font-semibold text-naila-text">Notificações</h2>
        <span class="text-xs text-naila-text-muted"><%= @notifications.size %></span>
      </div>
      <div data-testid="notifications-list">
        <% if @notifications.empty? %>
          <div class="px-4 py-8 text-center text-sm text-naila-text-muted">
            Nenhuma notificação enviada.
          </div>
        <% else %>
          <div class="divide-y divide-naila-border">
            <% @notifications.each do |notification| %>
              <div class="flex items-center justify-between px-4 py-2.5">
                <div class="flex items-center gap-2">
                  <%
                    channel_label = case notification.channel
                                    when "websocket" then "WebSocket"
                                    when "sms" then "SMS"
                                    when "push" then "Push"
                                    when "email" then "E-mail"
                                    when "civil_defense" then "Defesa Civil"
                                    end
                    notif_status_classes = case notification.status
                                          when "pending" then "bg-risk-attention/20 text-risk-attention"
                                          when "sent" then "bg-risk-normal/20 text-risk-normal"
                                          when "failed" then "bg-risk-high/20 text-risk-high"
                                          end
                    notif_status_label = case notification.status
                                        when "pending" then "Pendente"
                                        when "sent" then "Enviado"
                                        when "failed" then "Falhou"
                                        end
                  %>
                  <span class="text-sm text-naila-text"><%= channel_label %></span>
                  <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= notif_status_classes %>">
                    <%= notif_status_label %>
                  </span>
                </div>
                <div class="text-xs tabular-nums text-naila-text-muted">
                  <%= (notification.sent_at || notification.created_at).strftime("%d/%m %H:%M") %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
