<div class="rounded-xl border border-zinc-950/10 bg-white shadow-sm dark:border-white/10 dark:bg-zinc-900">
  <div class="border-b border-zinc-950/10 px-6 py-4 dark:border-white/10">
    <%= catalyst_subheading(rule.persisted? ? "Editar Regra" : "Nova Regra") %>
    <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">
      Esta regra se aplica a <strong>todos os alarmes</strong> que atingirem a severidade configurada.
    </p>
  </div>

  <div class="p-6">
    <%= form.error_summary %>

    <%= form.field_group do %>
      <%# ── Identificação ── %>
      <%= form.field do %>
        <%= form.label :name, "Nome" %>
        <%= form.text_field :name, required: true, placeholder: "Ex: Email Administradores — Alerta" %>
      <% end %>

      <%= form.field do %>
        <%= form.label :description, "Descrição" %>
        <%= form.text_area :description, rows: 2, placeholder: "Opcional — contexto sobre quando e por que esta regra dispara." %>
      <% end %>

      <%# ── Disparo ── %>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
        <%= form.field do %>
          <%= form.label :channel, "Canal" %>
          <%= form.select :channel, [ [ "Email", "email" ], [ "SMS", "sms" ] ] %>
        <% end %>

        <%= form.field do %>
          <%= form.label :min_severity, "Severidade mínima" %>
          <%= form.select :min_severity, [
                [ "Atenção (1)", 1 ],
                [ "Alerta (2)", 2 ],
                [ "Alerta Máximo (3)", 3 ],
                [ "Emergência (4)", 4 ]
              ] %>
          <%= form.description "A regra dispara quando a severidade do alarme for igual ou superior a este nível." %>
        <% end %>
      </div>

      <%# ── Destinatários por Cargo ── %>
      <div class="flex flex-col gap-4 rounded-lg border border-zinc-950/10 bg-zinc-50 p-4 dark:border-white/10 dark:bg-zinc-800">
        <div>
          <p class="text-sm font-semibold text-zinc-950 dark:text-white">Destinatários por Cargo</p>
          <p class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-400">Todos os usuários ativos com os cargos marcados receberão a notificação.</p>
        </div>
        <div class="flex items-center gap-3">
          <%= form.check_box :target_admins, {}, "true", "false" %>
          <%= form.label :target_admins, "Administradores" %>
        </div>
        <div class="flex items-center gap-3">
          <%= form.check_box :target_coordinators, {}, "true", "false" %>
          <%= form.label :target_coordinators, "Coordenadores" %>
        </div>
        <div class="flex items-center gap-3">
          <%= form.check_box :target_operators, {}, "true", "false" %>
          <%= form.label :target_operators, "Operadores" %>
        </div>
      </div>

      <%# ── Destinatários Específicos ── %>
      <div class="flex flex-col gap-4 rounded-lg border border-zinc-950/10 bg-zinc-50 p-4 dark:border-white/10 dark:bg-zinc-800">
        <div>
          <p class="text-sm font-semibold text-zinc-950 dark:text-white">Destinatários Específicos</p>
          <p class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-400">
            Usuários adicionais que receberão a notificação, além dos cargos selecionados acima.
          </p>
        </div>

        <% active_users = User.active.order(:name) %>
        <% if active_users.any? %>
          <div class="flex max-h-72 flex-col gap-3 overflow-y-auto">
            <%= form.collection_check_boxes :user_ids, active_users, :id, :name do |b| %>
              <% role_label = { "admin" => "Administrador", "coordinator" => "Coordenador", "operator" => "Operador" }[b.object.role] %>
              <% role_color = { "admin" => "purple", "coordinator" => "blue", "operator" => "zinc" }[b.object.role] %>
              <label class="flex cursor-pointer items-start gap-3">
                <%= b.check_box(class: "mt-0.5 size-4 rounded-[0.3125rem] border border-zinc-950/15 bg-white shadow-sm checked:border-transparent checked:bg-zinc-900 focus:outline-2 focus:outline-offset-2 focus:outline-blue-500 dark:bg-white/5 dark:border-white/15 dark:checked:bg-zinc-600") %>
                <span class="flex flex-col gap-0.5">
                  <span class="flex items-center gap-2 text-sm font-medium text-zinc-950 dark:text-white">
                    <%= b.object.name %>
                    <%= catalyst_badge role_label, color: role_color %>
                  </span>
                  <span class="text-xs text-zinc-500 dark:text-zinc-400">
                    <%= b.object.email_address %>
                    <% if b.object.phone_number.blank? %>
                      · <span class="text-amber-600 dark:text-amber-400">sem telefone (SMS ignorado)</span>
                    <% end %>
                  </span>
                </span>
              </label>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">Nenhum usuário ativo cadastrado.</p>
        <% end %>
      </div>

      <%# ── Status ── %>
      <%= form.field do %>
        <%= form.label :enabled, "Status" %>
        <%= form.select :enabled, [ [ "Ativada", "true" ], [ "Desativada", "false" ] ] %>
      <% end %>
    <% end %>
  </div>

  <div class="flex items-center justify-end gap-3 border-t border-zinc-950/10 px-6 py-4 dark:border-white/10">
    <%= catalyst_button_link "Cancelar", href: admin_notification_rules_path, variant: :plain %>
    <%= form.submit rule.persisted? ? "Salvar Alterações" : "Criar Regra" %>
  </div>
</div>
