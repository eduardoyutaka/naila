<% content_for(:title, "Naila — Regras de Notificação") %>

<%# ── Page Header ── %>
<div class="flex items-center justify-between mb-8">
  <%= catalyst_heading "Regras de Notificação", level: 1 %>
  <% if policy(NotificationRule).create? %>
    <%= catalyst_button_link href: new_admin_notification_rule_path, color: "sky" do %>
      <svg class="h-4 w-4" data-slot="icon" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Nova Regra
    <% end %>
  <% end %>
</div>

<%# ── Context Blurb ── %>
<div class="mb-6 rounded-xl border border-white/10 bg-zinc-800/30 p-4">
  <p class="text-sm text-zinc-300 leading-relaxed">
    As regras definem <strong class="text-white">quem recebe notificação</strong> (por cargo ou usuário específico)
    e <strong class="text-white">em qual canal</strong> (email ou SMS) quando um alarme atingir a severidade configurada.
    Elas se aplicam a <strong class="text-white">todos os alarmes</strong> do sistema.
  </p>
</div>

<%# ── Summary Cards ── %>
<div class="mb-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
  <div class="rounded-xl border border-white/10 bg-zinc-800/50 p-4">
    <p class="text-sm font-semibold uppercase tracking-wider text-zinc-300">Total</p>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-white"><%= @summary_counts[:total] %></div>
  </div>
  <div class="rounded-xl border border-white/10 bg-zinc-800/50 p-4">
    <p class="text-sm font-semibold uppercase tracking-wider text-zinc-300">Email</p>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sky-400"><%= @summary_counts[:email] %></div>
  </div>
  <div class="rounded-xl border border-white/10 bg-zinc-800/50 p-4">
    <p class="text-sm font-semibold uppercase tracking-wider text-zinc-300">SMS</p>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sky-500"><%= @summary_counts[:sms] %></div>
  </div>
  <div class="rounded-xl border border-white/10 bg-zinc-800/50 p-4">
    <p class="text-sm font-semibold uppercase tracking-wider text-zinc-300">Ativadas</p>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sensor-online"><%= @summary_counts[:enabled] %></div>
  </div>
</div>

<%# ── Filter Bar ── %>
<%= form_with url: admin_notification_rules_path, method: :get, scope: :q, class: "mb-6 flex flex-wrap items-end gap-4" do |f| %>
  <div>
    <%= f.label :channel, "Canal", class: "block text-sm font-medium text-zinc-400 mb-1" %>
    <%= f.select :channel, options_for_select([ [ "Todos", "" ], [ "Email", "email" ], [ "SMS", "sms" ] ], params.dig(:q, :channel)),
          {}, class: "rounded-lg border border-white/10 bg-zinc-800 px-3 py-1.5 text-sm text-white focus:border-sky-500 focus:ring-1 focus:ring-sky-500",
          data: { controller: "shared--auto-submit", action: "change->shared--auto-submit#submit" } %>
  </div>
  <div>
    <%= f.label :min_severity, "Severidade", class: "block text-sm font-medium text-zinc-400 mb-1" %>
    <%= f.select :min_severity, options_for_select([ [ "Todas", "" ], [ "Atenção (1+)", "1" ], [ "Alerta (2+)", "2" ], [ "Alerta Máximo (3+)", "3" ], [ "Emergência (4)", "4" ] ], params.dig(:q, :min_severity)),
          {}, class: "rounded-lg border border-white/10 bg-zinc-800 px-3 py-1.5 text-sm text-white focus:border-sky-500 focus:ring-1 focus:ring-sky-500",
          data: { controller: "shared--auto-submit", action: "change->shared--auto-submit#submit" } %>
  </div>
  <div>
    <%= f.label :enabled, "Status", class: "block text-sm font-medium text-zinc-400 mb-1" %>
    <%= f.select :enabled, options_for_select([ [ "Todos", "" ], [ "Ativada", "true" ], [ "Desativada", "false" ] ], params.dig(:q, :enabled)),
          {}, class: "rounded-lg border border-white/10 bg-zinc-800 px-3 py-1.5 text-sm text-white focus:border-sky-500 focus:ring-1 focus:ring-sky-500",
          data: { controller: "shared--auto-submit", action: "change->shared--auto-submit#submit" } %>
  </div>
<% end %>

<%# ── Rules Table ── %>
<% if @rules.empty? %>
  <div class="rounded-xl border border-white/10 bg-zinc-800/50 px-4 py-8 text-center">
    <%= catalyst_text "Nenhuma regra encontrada." %>
    <% if params[:q].present? %>
      <div class="mt-4">
        <%= catalyst_button_link "Limpar filtros", href: admin_notification_rules_path, variant: :plain %>
      </div>
    <% end %>
  </div>
<% else %>
  <%= catalyst_table(dense: true) do %>
    <%= catalyst_table_head do %>
      <tr>
        <%= catalyst_th "Nome" %>
        <%= catalyst_th "Canal" %>
        <%= catalyst_th "Severidade mín." %>
        <%= catalyst_th "Cargos" %>
        <%= catalyst_th "Usuários" %>
        <%= catalyst_th "Status" %>
        <%= catalyst_th "Ações", class: "text-right" %>
      </tr>
    <% end %>
    <%= catalyst_table_body do %>
      <% @rules.each do |rule| %>
        <%= catalyst_table_row do %>
          <%= catalyst_td do %>
            <div class="text-sm font-medium text-zinc-950 dark:text-white"><%= rule.name %></div>
            <% if rule.description.present? %>
              <div class="text-xs text-zinc-600 dark:text-zinc-300 line-clamp-1"><%= rule.description %></div>
            <% end %>
          <% end %>

          <%= catalyst_td do %>
            <% channel_color = rule.channel == "email" ? "sky" : "indigo" %>
            <% channel_label = rule.channel == "email" ? "Email" : "SMS" %>
            <%= catalyst_badge channel_label, color: channel_color %>
          <% end %>

          <%= catalyst_td do %>
            <%= severity_badge(rule.min_severity) %>
          <% end %>

          <%= catalyst_td do %>
            <% labels = rule.targeted_role_labels %>
            <% if labels.any? %>
              <span class="text-xs text-zinc-600 dark:text-zinc-300"><%= labels.join(", ") %></span>
            <% else %>
              <span class="text-xs text-zinc-500 dark:text-zinc-500">—</span>
            <% end %>
          <% end %>

          <%= catalyst_td do %>
            <% count = rule.users.size %>
            <% if count.zero? %>
              <span class="text-xs text-zinc-500 dark:text-zinc-500">—</span>
            <% else %>
              <span class="text-xs text-zinc-600 dark:text-zinc-300"><%= count %> <%= "usuário".pluralize(count) %></span>
            <% end %>
          <% end %>

          <%= catalyst_td do %>
            <div class="flex items-center gap-1.5">
              <span class="inline-block h-2 w-2 rounded-full <%= rule.enabled? ? 'bg-sensor-online' : 'bg-sensor-offline' %>"></span>
              <span class="text-xs text-zinc-600 dark:text-zinc-300"><%= rule.enabled? ? "Ativada" : "Desativada" %></span>
            </div>
          <% end %>

          <%= catalyst_td class: "text-right" do %>
            <div class="flex items-center justify-end gap-2">
              <% if policy(rule).update? %>
                <%= link_to edit_admin_notification_rule_path(rule),
                      class: "rounded-md p-1.5 text-zinc-500 hover:bg-zinc-950/5 hover:text-sky-500 dark:text-zinc-400 dark:hover:bg-white/5 transition-colors",
                      title: "Editar",
                      aria: { label: "Editar #{rule.name}" } do %>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                  </svg>
                <% end %>
              <% end %>
              <% if policy(rule).destroy? %>
                <%= button_to admin_notification_rule_path(rule), method: :delete,
                      class: "rounded-md p-1.5 text-zinc-500 hover:bg-red-500/10 hover:text-red-400 dark:text-zinc-400 transition-colors",
                      title: "Remover",
                      aria: { label: "Remover #{rule.name}" },
                      form: { data: { turbo_confirm: "Remover a regra “#{rule.name}”?" } } do %>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                  </svg>
                <% end %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
