<% content_for(:title, "Naila — #{@monitoring_station.name}") %>

<%
  status_label = case @monitoring_station.status
                 when "active" then "Ativo"
                 when "maintenance" then "Manutenção"
                 when "inactive" then "Inativo"
                 end
  status_color = case @monitoring_station.status
                 when "active" then "green"
                 when "maintenance" then "yellow"
                 when "inactive" then "red"
                 end
  chart_config = {
    "precipitation" => { type: "bar",  color: "sensor-pluviometer", label: "Precipitação 24h" },
    "temperature"   => { type: "line", color: "sensor-weather",     label: "Temperatura 24h" },
  }
%>

<% if turbo_frame_request? %>
<%= turbo_frame_tag "sensor_detail" do %>
  <%# ════════════════════════════════════════════════════════════ %>
  <%# SIDE-SHEET LAYOUT — keep compact, avoid changing this block %>
  <%# ════════════════════════════════════════════════════════════ %>

  <div class="sticky top-0 z-10 flex items-center justify-between border-b border-white/10 bg-zinc-900 px-4 py-3">
    <h2 class="truncate text-sm font-semibold text-white"><%= @monitoring_station.name %></h2>
    <button data-action="admin--side-sheet#close"
            class="flex h-6 w-6 items-center justify-center rounded text-zinc-400 hover:bg-zinc-800 hover:text-white"
            title="Fechar">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="space-y-5 p-4">
    <div>
      <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-zinc-300">Informações</div>
      <div class="space-y-2">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center gap-1 text-xs">
            <span class="inline-block h-1.5 w-1.5 rounded-full <%= "bg-sensor-#{status_color == 'green' ? 'online' : status_color == 'yellow' ? 'degraded' : 'offline'}" %>"></span>
            <span class="<%= "text-sensor-#{status_color == 'green' ? 'online' : status_color == 'yellow' ? 'degraded' : 'offline'}" %>"><%= status_label %></span>
          </span>
        </div>
        <div class="grid grid-cols-2 gap-2 text-xs">
          <div>
            <span class="text-zinc-400">ID Externo</span>
            <div class="font-mono text-white"><%= @monitoring_station.external_id %></div>
          </div>
          <div>
            <span class="text-zinc-400">Fonte</span>
            <div class="text-white"><%= @monitoring_station.data_source.upcase %></div>
          </div>
          <% if @monitoring_station.elevation_m %>
            <div>
              <span class="text-zinc-400">Elevação</span>
              <div class="tabular-nums text-white"><%= number_with_precision(@monitoring_station.elevation_m, precision: 0) %> m</div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <% if @monitoring_station.sensors.any? %>
      <div>
        <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-zinc-300">Sensores</div>
        <div class="space-y-1.5">
          <% @monitoring_station.sensors.each do |sensor| %>
            <% sensor_status_css = case sensor.status
                                   when "active" then "text-sensor-online"
                                   when "maintenance" then "text-sensor-degraded"
                                   else "text-sensor-offline"
                                   end %>
            <div class="flex items-center justify-between rounded-lg bg-zinc-800 px-3 py-2">
              <div class="flex items-center gap-2">
                <%= sensor_type_badge(sensor.sensor_type) %>
                <% sensor_last = sensor.last_reading %>
                <% if sensor_last %>
                  <span class="tabular-nums text-xs text-white">
                    <%= number_with_precision(sensor_last.value, precision: 1) %> <%= sensor.unit %>
                  </span>
                <% end %>
              </div>
              <span class="flex items-center gap-1 text-xs <%= sensor_status_css %>">
                <span class="inline-block h-1.5 w-1.5 rounded-full bg-current"></span>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div>
      <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-zinc-300">Localização</div>
      <div class="space-y-1 text-xs">
        <% if @monitoring_station.neighborhood %>
          <div class="flex justify-between">
            <span class="text-zinc-400">Bairro</span>
            <span class="text-white"><%= @monitoring_station.neighborhood.name %></span>
          </div>
        <% end %>
        <% if @monitoring_station.river %>
          <div class="flex justify-between">
            <span class="text-zinc-400">Rio</span>
            <span class="text-white"><%= @monitoring_station.river.name %></span>
          </div>
        <% end %>
        <% if @monitoring_station.location %>
          <div class="flex justify-between">
            <span class="text-zinc-400">Coordenadas</span>
            <span class="font-mono tabular-nums text-white">
              <%= number_with_precision(@monitoring_station.location.y, precision: 4) %>,
              <%= number_with_precision(@monitoring_station.location.x, precision: 4) %>
            </span>
          </div>
        <% end %>
      </div>
    </div>

    <% station_last = @monitoring_station.last_reading %>
    <% if station_last %>
      <div class="rounded-lg bg-zinc-800 p-3">
        <div class="text-xs text-zinc-400">Última Leitura</div>
        <div class="mt-1 text-2xl font-semibold tabular-nums text-white">
          <%= number_with_precision(station_last.value, precision: 1) %>
        </div>
        <div class="text-xs text-zinc-400">
          <%= time_ago_in_words(station_last.recorded_at) %> atrás
        </div>
      </div>
    <% end %>

    <% if @readings_by_type.any? %>
      <% @readings_by_type.each do |reading_type, readings| %>
        <% config = chart_config[reading_type] || { type: "line", color: "#3b82f6", label: "#{reading_type.humanize} 24h" } %>
        <div>
          <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-zinc-300"><%= config[:label] %></div>
          <div data-testid="reading-chart-<%= reading_type %>"
               data-controller="admin--reading-chart"
               data-admin--reading-chart-readings-value="<%= readings.map { |r| [r.recorded_at.iso8601, r.value] }.to_json %>"
               data-admin--reading-chart-unit-value="<%= readings.first.unit %>"
               data-admin--reading-chart-chart-type-value="<%= config[:type] %>"
               data-admin--reading-chart-color-value="<%= config[:color] %>"
               data-admin--reading-chart-thresholds-value="[]">
            <div data-admin--reading-chart-target="chart" class="h-40 w-full rounded-lg bg-zinc-800"></div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div>
        <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-zinc-300">Leituras 24h</div>
        <div class="rounded-lg border border-white/10 px-3 py-4 text-center text-xs text-zinc-400">
          Nenhuma leitura disponível.
        </div>
      </div>
    <% end %>

    <div class="pt-1">
      <%= link_to "Ver detalhes completos", admin_monitoring_station_path(@monitoring_station),
            data: { turbo_frame: "_top" },
            class: "block w-full rounded-lg bg-sky-500 px-4 py-2 text-center text-sm font-medium text-white hover:bg-sky-500/90 transition-colors" %>
    </div>
  </div>

<% end %>
<% else %>
  <%# ════════════════════════════════════════════════════ %>
  <%# FULL-PAGE LAYOUT %>
  <%# ════════════════════════════════════════════════════ %>

  <div class="mb-6 flex items-center gap-4">
    <%= catalyst_button_link "Estações", href: admin_monitoring_stations_path, variant: :plain do %>
      <svg data-slot="icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
      </svg>
      Voltar
    <% end %>
  </div>

  <div class="mb-8">
    <div class="mb-2 flex flex-wrap items-center gap-2">
      <%= catalyst_badge status_label, color: status_color %>
    </div>
    <%= catalyst_heading @monitoring_station.name, level: 1 %>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-6">
      <div class="rounded-xl border border-white/10 bg-zinc-800/50">
        <div class="border-b border-white/10 px-6 py-4">
          <%= catalyst_subheading "Informações" %>
        </div>
        <%= catalyst_dl class: "px-6" do %>
          <%= catalyst_dt "ID Externo" %><%= catalyst_dd @monitoring_station.external_id %>
          <%= catalyst_dt "Fonte de Dados" %><%= catalyst_dd @monitoring_station.data_source.upcase %>
          <% if @monitoring_station.elevation_m %>
            <%= catalyst_dt "Elevação" %><%= catalyst_dd "#{number_with_precision(@monitoring_station.elevation_m, precision: 0)} m" %>
          <% end %>
        <% end %>
      </div>

      <% if @monitoring_station.neighborhood || @monitoring_station.river || @monitoring_station.location %>
        <div class="rounded-xl border border-white/10 bg-zinc-800/50">
          <div class="border-b border-white/10 px-6 py-4">
            <%= catalyst_subheading "Localização" %>
          </div>
          <%= catalyst_dl class: "px-6" do %>
            <% if @monitoring_station.neighborhood %>
              <%= catalyst_dt "Bairro" %><%= catalyst_dd @monitoring_station.neighborhood.name %>
            <% end %>
            <% if @monitoring_station.river %>
              <%= catalyst_dt "Rio" %><%= catalyst_dd @monitoring_station.river.name %>
            <% end %>
            <% if @monitoring_station.location %>
              <%= catalyst_dt "Coordenadas" %>
              <%= catalyst_dd "#{number_with_precision(@monitoring_station.location.y, precision: 4)}, #{number_with_precision(@monitoring_station.location.x, precision: 4)}" %>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <% if @monitoring_station.sensors.any? %>
        <div class="rounded-xl border border-white/10 bg-zinc-800/50">
          <div class="border-b border-white/10 px-6 py-4">
            <%= catalyst_subheading "Sensores" %>
          </div>
          <div class="divide-y divide-white/10">
            <% @monitoring_station.sensors.each do |sensor| %>
              <% sensor_status_css = case sensor.status
                                     when "active" then "text-sensor-online"
                                     when "maintenance" then "text-sensor-degraded"
                                     else "text-sensor-offline"
                                     end %>
              <div class="flex items-center justify-between px-6 py-3">
                <div class="flex items-center gap-3">
                  <%= sensor_type_badge(sensor.sensor_type) %>
                  <% sensor_last = sensor.last_reading %>
                  <% if sensor_last %>
                    <span class="tabular-nums text-sm text-white">
                      <%= number_with_precision(sensor_last.value, precision: 1) %> <%= sensor.unit %>
                    </span>
                  <% end %>
                </div>
                <span class="flex items-center gap-1.5 text-xs <%= sensor_status_css %>">
                  <span class="inline-block h-1.5 w-1.5 rounded-full bg-current"></span>
                  <% case sensor.status
                     when "active" then %>Ativo<% when "maintenance" then %>Manutenção<% else %>Inativo<% end %>
                </span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="rounded-xl border border-white/10 bg-zinc-800/50">
        <div class="border-b border-white/10 px-6 py-4">
          <%= catalyst_subheading "Leituras 24h" %>
        </div>
        <div class="p-6 space-y-6">
          <% if @readings_by_type.any? %>
            <% @readings_by_type.each do |reading_type, readings| %>
              <% config = chart_config[reading_type] || { type: "line", color: "#3b82f6", label: "#{reading_type.humanize} 24h" } %>
              <div>
                <div class="mb-2 text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-300"><%= config[:label] %></div>
                <div data-testid="reading-chart-<%= reading_type %>"
                     data-controller="admin--reading-chart"
                     data-admin--reading-chart-readings-value="<%= readings.map { |r| [r.recorded_at.iso8601, r.value] }.to_json %>"
                     data-admin--reading-chart-unit-value="<%= readings.first.unit %>"
                     data-admin--reading-chart-chart-type-value="<%= config[:type] %>"
                     data-admin--reading-chart-color-value="<%= config[:color] %>"
                     data-admin--reading-chart-thresholds-value="[]">
                  <div data-admin--reading-chart-target="chart" class="h-40 w-full rounded-lg bg-zinc-800"></div>
                </div>
              </div>
            <% end %>
          <% else %>
            <div class="py-4 text-center">
              <%= catalyst_text "Nenhuma leitura disponível nas últimas 24 horas." %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="rounded-xl border border-white/10 bg-zinc-800/50">
        <div class="border-b border-white/10 px-6 py-4">
          <%= catalyst_subheading "Última Leitura" %>
        </div>
        <div class="p-6">
          <% station_last = @monitoring_station.last_reading %>
          <% if station_last %>
            <div class="text-3xl font-semibold tabular-nums text-white">
              <%= number_with_precision(station_last.value, precision: 1) %>
            </div>
            <div class="mt-1">
              <%= catalyst_text "#{time_ago_in_words(station_last.recorded_at)} atrás" %>
            </div>
          <% else %>
            <%= catalyst_text "Sem leituras recentes." %>
          <% end %>
        </div>
      </div>

      <% if policy(@monitoring_station).update? || policy(@monitoring_station).destroy? %>
        <div class="rounded-xl border border-white/10 bg-zinc-800/50">
          <div class="border-b border-white/10 px-6 py-4">
            <%= catalyst_subheading "Ações" %>
          </div>
          <div class="p-4 space-y-2">
            <% if policy(@monitoring_station).update? %>
              <%= catalyst_button_link "Editar Estação", href: edit_admin_monitoring_station_path(@monitoring_station), variant: :outline, color: "zinc", class: "w-full justify-center" %>
            <% end %>
            <% if policy(@monitoring_station).destroy? %>
              <%= button_to admin_monitoring_station_path(@monitoring_station),
                    method: :delete,
                    class: "flex w-full items-center justify-center gap-2 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-2.5 text-sm font-medium text-red-400 hover:bg-red-500/20 transition-colors",
                    form: { data: { turbo_confirm: "Tem certeza que deseja excluir esta estação?" } } do %>
                Excluir Estação
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
