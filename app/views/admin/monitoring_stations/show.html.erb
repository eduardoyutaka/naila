<%= turbo_frame_tag "sensor_detail" do %>
  <%# ── Header ── %>
  <div class="sticky top-0 z-10 flex items-center justify-between border-b border-naila-border bg-naila-surface px-4 py-3">
    <h2 class="text-sm font-semibold text-naila-text truncate"><%= @monitoring_station.name %></h2>
    <button data-action="admin--side-sheet#close"
            class="flex h-6 w-6 items-center justify-center rounded text-naila-text-muted hover:bg-naila-elevated hover:text-naila-text"
            title="Fechar">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="space-y-5 p-4">
    <%# ── Station Info ── %>
    <div>
      <div class="mb-2 text-xs font-medium uppercase tracking-wider text-naila-text-muted">Informações</div>
      <div class="space-y-2">
        <div class="flex items-center gap-2">
          <% status_label = case @monitoring_station.status
                            when "active" then "Ativo"
                            when "maintenance" then "Manutenção"
                            when "inactive" then "Inativo"
                            end %>
          <% status_color = case @monitoring_station.status
                            when "active" then "text-sensor-online"
                            when "maintenance" then "text-sensor-degraded"
                            when "inactive" then "text-sensor-offline"
                            end %>
          <span class="flex items-center gap-1 text-xs <%= status_color %>">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-current"></span>
            <%= status_label %>
          </span>
        </div>

        <div class="grid grid-cols-2 gap-2 text-xs">
          <div>
            <span class="text-naila-text-muted">ID Externo</span>
            <div class="font-mono text-naila-text"><%= @monitoring_station.external_id %></div>
          </div>
          <div>
            <span class="text-naila-text-muted">Fonte</span>
            <div class="text-naila-text"><%= @monitoring_station.data_source.upcase %></div>
          </div>
          <% if @monitoring_station.elevation_m %>
            <div>
              <span class="text-naila-text-muted">Elevação</span>
              <div class="tabular-nums text-naila-text"><%= number_with_precision(@monitoring_station.elevation_m, precision: 0) %> m</div>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Sensors ── %>
    <% if @monitoring_station.sensors.any? %>
      <div>
        <div class="mb-2 text-xs font-medium uppercase tracking-wider text-naila-text-muted">Sensores</div>
        <div class="space-y-1.5">
          <% @monitoring_station.sensors.each do |sensor| %>
            <% sensor_type_label = case sensor.sensor_type
                                   when "pluviometer" then "Pluviômetro"
                                   when "river_gauge" then "Fluviômetro"
                                   when "weather_station" then "Estação Meteorológica"
                                   end %>
            <% sensor_type_color = case sensor.sensor_type
                                   when "pluviometer" then "bg-[#3b82f6]/20 text-[#3b82f6]"
                                   when "river_gauge" then "bg-[#06b6d4]/20 text-[#06b6d4]"
                                   when "weather_station" then "bg-[#8b5cf6]/20 text-[#8b5cf6]"
                                   end %>
            <% sensor_status_color = case sensor.status
                                     when "active" then "text-sensor-online"
                                     when "maintenance" then "text-sensor-degraded"
                                     when "inactive" then "text-sensor-offline"
                                     end %>
            <div class="flex items-center justify-between rounded-lg bg-naila-elevated px-3 py-2">
              <div class="flex items-center gap-2">
                <span class="rounded px-1.5 py-0.5 text-xs font-medium <%= sensor_type_color %>"><%= sensor_type_label %></span>
                <% if sensor.last_reading_value %>
                  <span class="tabular-nums text-xs text-naila-text">
                    <%= number_with_precision(sensor.last_reading_value, precision: 1) %> <%= sensor.unit %>
                  </span>
                <% end %>
              </div>
              <span class="flex items-center gap-1 text-xs <%= sensor_status_color %>">
                <span class="inline-block h-1.5 w-1.5 rounded-full bg-current"></span>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── Location ── %>
    <div>
      <div class="mb-2 text-xs font-medium uppercase tracking-wider text-naila-text-muted">Localização</div>
      <div class="space-y-1 text-xs">
        <% if @monitoring_station.neighborhood %>
          <div class="flex justify-between">
            <span class="text-naila-text-muted">Bairro</span>
            <span class="text-naila-text"><%= @monitoring_station.neighborhood.name %></span>
          </div>
        <% end %>
        <% if @monitoring_station.river %>
          <div class="flex justify-between">
            <span class="text-naila-text-muted">Rio</span>
            <span class="text-naila-text"><%= @monitoring_station.river.name %></span>
          </div>
        <% end %>
        <% if @monitoring_station.location %>
          <div class="flex justify-between">
            <span class="text-naila-text-muted">Coordenadas</span>
            <span class="font-mono tabular-nums text-naila-text">
              <%= number_with_precision(@monitoring_station.location.y, precision: 4) %>,
              <%= number_with_precision(@monitoring_station.location.x, precision: 4) %>
            </span>
          </div>
        <% end %>
      </div>
    </div>

    <%# ── Last Reading ── %>
    <% if @monitoring_station.last_reading_value && @monitoring_station.last_reading_at %>
      <div class="rounded-lg bg-naila-elevated p-3">
        <div class="text-xs text-naila-text-muted">Última Leitura</div>
        <div class="mt-1 text-2xl font-semibold tabular-nums text-naila-text">
          <%= number_with_precision(@monitoring_station.last_reading_value, precision: 1) %>
        </div>
        <div class="text-xs text-naila-text-muted">
          <%= time_ago_in_words(@monitoring_station.last_reading_at) %> atrás
        </div>
      </div>
    <% end %>

    <%# ── Reading Charts ── %>
    <% chart_config = {
         "precipitation" => { type: "bar", color: "#3b82f6", label: "Precipitação 24h" },
         "river_level"   => { type: "line", color: "#06b6d4", label: "Nível do Rio 24h" },
         "temperature"   => { type: "line", color: "#8b5cf6", label: "Temperatura 24h" },
       } %>
    <% if @readings_by_type.any? %>
      <% @readings_by_type.each do |reading_type, readings| %>
        <% config = chart_config[reading_type] || { type: "line", color: "#3b82f6", label: "#{reading_type.humanize} 24h" } %>
        <div>
          <div class="mb-2 text-xs font-medium uppercase tracking-wider text-naila-text-muted"><%= config[:label] %></div>
          <div data-testid="reading-chart-<%= reading_type %>"
               data-controller="admin--reading-chart"
               data-admin--reading-chart-readings-value="<%= readings.map { |r| [r.recorded_at.iso8601, r.value] }.to_json %>"
               data-admin--reading-chart-unit-value="<%= readings.first.unit %>"
               data-admin--reading-chart-chart-type-value="<%= config[:type] %>"
               data-admin--reading-chart-color-value="<%= config[:color] %>"
               data-admin--reading-chart-thresholds-value="<%= (@thresholds_by_param[reading_type] || []).map { |t| { value: t.value, severity: t.severity, label: "#{t.value} #{t.unit}" } }.to_json %>">
            <div data-admin--reading-chart-target="chart"
                 class="h-40 w-full rounded-lg bg-naila-elevated"></div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div>
        <div class="mb-2 text-xs font-medium uppercase tracking-wider text-naila-text-muted">Leituras 24h</div>
        <div class="rounded-lg border border-naila-border px-3 py-4 text-center text-xs text-naila-text-muted">
          Nenhuma leitura disponível.
        </div>
      </div>
    <% end %>

    <%# ── Full Details Link ── %>
    <div class="pt-1">
      <%= link_to "Ver detalhes completos", admin_monitoring_station_path(@monitoring_station),
            data: { turbo_frame: "_top" },
            class: "block w-full rounded-lg bg-naila-accent px-4 py-2 text-center text-sm font-medium text-white hover:bg-naila-accent/90 transition-colors" %>
    </div>
  </div>
<% end %>
