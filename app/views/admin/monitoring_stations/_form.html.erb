<div class="rounded-xl border border-white/10 bg-zinc-800/50 shadow-sm">
  <div class="border-b border-white/10 px-6 py-4">
    <%= catalyst_subheading(monitoring_station.persisted? ? "Editar Estação" : "Nova Estação") %>
  </div>

  <div class="p-6">
    <%= form.error_summary %>

    <%= form.field_group do %>
      <%= form.field do %>
        <%= form.label :name, "Nome" %>
        <%= form.text_field :name, required: true, placeholder: "Ex: Pluviômetro Centro" %>
      <% end %>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
        <%= form.field do %>
          <%= form.label :external_id, "ID Externo" %>
          <%= form.text_field :external_id, required: true, placeholder: "Ex: PLUV-001" %>
        <% end %>
        <%= form.field do %>
          <%= form.label :data_source, "Fonte de Dados" %>
          <%= form.text_field :data_source, required: true, placeholder: "Ex: cemaden, ana" %>
        <% end %>
      </div>

      <%= form.field do %>
        <%= form.label :status, "Status" %>
        <%= form.select :status, [["Ativo", "active"], ["Inativo", "inactive"], ["Manutenção", "maintenance"]] %>
      <% end %>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
        <%= form.field do %>
          <%= form.label :latitude, "Latitude" %>
          <%= form.text_field :latitude,
                value: monitoring_station.location&.y,
                placeholder: "Ex: -25.4284",
                inputmode: "decimal" %>
        <% end %>
        <%= form.field do %>
          <%= form.label :longitude, "Longitude" %>
          <%= form.text_field :longitude,
                value: monitoring_station.location&.x,
                placeholder: "Ex: -49.2733",
                inputmode: "decimal" %>
        <% end %>
      </div>

      <%= form.field do %>
        <%= form.label :elevation_m, "Elevação (m)" %>
        <%= form.text_field :elevation_m, placeholder: "Ex: 934", inputmode: "decimal" %>
      <% end %>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
        <%= form.field do %>
          <%= form.label :neighborhood_id, "Bairro" %>
          <%= form.select :neighborhood_id, Neighborhood.order(:name).pluck(:name, :id), { include_blank: "Nenhum" } %>
        <% end %>
        <%= form.field do %>
          <%= form.label :river_basin_id, "Bacia Hidrográfica" %>
          <%= form.select :river_basin_id, RiverBasin.order(:name).pluck(:name, :id), { prompt: "Selecione a bacia" }, required: true %>
        <% end %>
      </div>

      <%= form.field do %>
        <%= form.label :river_id, "Rio" %>
        <%= form.select :river_id, River.order(:name).pluck(:name, :id), { include_blank: "Nenhum" } %>
      <% end %>
    <% end %>
  </div>

  <div class="flex items-center justify-end gap-3 border-t border-white/10 px-6 py-4">
    <%= catalyst_button_link "Cancelar", href: admin_monitoring_stations_path, variant: :plain %>
    <%= form.submit monitoring_station.persisted? ? "Salvar Alterações" : "Criar Estação" %>
  </div>
</div>
