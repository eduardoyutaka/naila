<% input_class = "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text placeholder-naila-text-muted/50 outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent" %>

<div class="rounded-xl border border-naila-border bg-naila-surface">
  <div class="border-b border-naila-border px-6 py-4">
    <h2 class="text-sm font-semibold text-naila-text">Dados do Limiar</h2>
  </div>

  <div class="p-6 space-y-5">
    <% if defined?(return_alert) && return_alert %>
      <%= form.hidden_field :alert_id, value: return_alert.id, name: "alert_id" %>
    <% end %>

    <% if alert_threshold.errors.any? %>
      <div class="rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3">
        <p class="text-sm font-medium text-red-400">
          <%= alert_threshold.errors.count %> erro(s) impediu(iram) o salvamento:
        </p>
        <ul class="mt-2 list-disc pl-5 text-sm text-red-400/80">
          <% alert_threshold.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Parâmetro + Tipo de Limiar %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :parameter, "Parâmetro", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.select :parameter,
              [["Precipitação", "precipitation"], ["Nível do Rio", "river_level"]],
              { prompt: "Selecione o parâmetro" },
              required: true, class: input_class %>
      </div>
      <div>
        <%= form.label :threshold_type, "Tipo de Limiar", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.select :threshold_type,
              [["Acumulado 1h", "accumulated_1h"], ["Acumulado 3h", "accumulated_3h"], ["Instantâneo", "instant"]],
              { prompt: "Selecione o tipo" },
              required: true, class: input_class %>
      </div>
    </div>

    <%# Valor + Unidade %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :value, "Valor", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.number_field :value, step: 0.1, min: 0, required: true,
              class: input_class, placeholder: "Ex: 60.0" %>
      </div>
      <div>
        <%= form.label :unit, "Unidade", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.select :unit,
              [["mm (milímetros)", "mm"], ["m (metros)", "m"]],
              { prompt: "Selecione a unidade" },
              required: true, class: input_class %>
      </div>
    </div>

    <%# Comparação + Severidade %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :comparison, "Comparação", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.select :comparison,
              [["≥ Maior ou igual", "gte"], ["> Maior que", "gt"], ["≤ Menor ou igual", "lte"], ["< Menor que", "lt"]],
              {},
              required: true, class: input_class %>
      </div>
      <div>
        <%= form.label :severity, "Severidade", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.select :severity,
              [["Atenção (1)", 1], ["Alerta (2)", 2], ["Alerta Máximo (3)", 3], ["Emergência (4)", 4]],
              { prompt: "Selecione a severidade" },
              required: true, class: input_class %>
      </div>
    </div>

    <%# Bacia Hidrográfica + Rio %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :river_basin_id, "Bacia Hidrográfica", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.select :river_basin_id,
              RiverBasin.active.order(:name).pluck(:name, :id),
              { include_blank: "Nenhuma (global)" },
              class: input_class %>
      </div>
      <div>
        <%= form.label :river_id, "Rio", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.select :river_id,
              River.order(:name).pluck(:name, :id),
              { include_blank: "Nenhum (global)" },
              class: input_class %>
      </div>
    </div>

    <%# Cooldown + Ativo %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :cooldown_minutes, "Cooldown (minutos)", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.number_field :cooldown_minutes, min: 1, required: true,
              class: input_class, placeholder: "Ex: 60" %>
        <p class="mt-1 text-xs text-naila-text-muted">Tempo mínimo entre alertas consecutivos.</p>
      </div>
      <div>
        <%= form.label :active, "Status", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <label class="flex items-center gap-3 rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 cursor-pointer">
          <%= form.check_box :active, class: "h-4 w-4 rounded border-naila-border bg-naila-elevated text-naila-accent focus:ring-naila-accent" %>
          <span class="text-sm text-naila-text">Limiar ativo</span>
        </label>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center justify-end gap-3 border-t border-naila-border px-6 py-4">
    <%= link_to "Cancelar",
          (defined?(return_alert) && return_alert ? admin_alert_path(return_alert) : admin_alerts_path),
          class: "text-sm text-naila-text-muted hover:text-naila-text transition-colors" %>
    <%= form.submit alert_threshold.persisted? ? "Salvar Alterações" : "Criar Limiar",
          class: "rounded-lg bg-naila-accent px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-naila-accent/90 focus:outline-none focus:ring-2 focus:ring-naila-accent focus:ring-offset-2 focus:ring-offset-naila-bg cursor-pointer" %>
  </div>
</div>
