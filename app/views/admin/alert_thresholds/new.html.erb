<% content_for(:title, "Naila — Novo Limiar de Alerta") %>

<div class="mx-auto max-w-2xl">
  <div class="mb-4">
    <% if @return_alert %>
      <%= link_to admin_alert_path(@return_alert), class: "inline-flex items-center gap-1 text-sm text-naila-text-muted hover:text-naila-accent transition-colors" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
        </svg>
        Voltar ao alerta
      <% end %>
    <% end %>
  </div>

  <div class="mb-6">
    <h1 class="text-xl font-semibold text-naila-text">Novo Limiar de Alerta</h1>
  </div>

  <%= form_with model: [:admin, @alert_threshold] do |f| %>
    <%= render "form", form: f, alert_threshold: @alert_threshold, return_alert: @return_alert %>
  <% end %>
</div>
