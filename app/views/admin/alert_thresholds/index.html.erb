<% content_for(:title, "Naila — Limiares de Alerta") %>

<%
  active_thresholds = @alert_thresholds.select(&:active?)
  inactive_thresholds = @alert_thresholds.reject(&:active?)

  parameter_labels = {
    "precipitation" => "Precipitação",
    "precipitation_1h" => "Precipitação 1h",
    "precipitation_3h" => "Precipitação 3h",
    "river_level" => "Nível do Rio"
  }

  comparison_labels = { "gt" => ">", "gte" => "≥", "lt" => "<", "lte" => "≤" }
%>

<%# ── Summary Cards ── %>
<div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
  <div class="rounded-xl border border-naila-border bg-naila-surface p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Total de Limiares</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-naila-text"><%= @alert_thresholds.size %></div>
  </div>
  <div class="rounded-xl border border-naila-border bg-naila-surface p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Limiares Ativos</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-risk-normal"><%= active_thresholds.size %></div>
  </div>
  <div class="rounded-xl border border-naila-border bg-naila-surface p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Limiares Inativos</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-naila-text-muted"><%= inactive_thresholds.size %></div>
  </div>
</div>

<%# ── Thresholds Table ── %>
<div class="rounded-xl border border-naila-border bg-naila-surface">
  <div class="flex items-center justify-between border-b border-naila-border px-4 py-3">
    <h2 class="text-sm font-semibold text-naila-text">Limiares de Alerta</h2>
    <% if policy(AlertThreshold).create? %>
      <%= link_to new_admin_alert_threshold_path,
            class: "inline-flex items-center gap-1.5 rounded-lg bg-naila-accent px-3 py-2 text-xs font-medium text-white transition-colors hover:bg-naila-accent/90" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Novo Limiar
      <% end %>
    <% end %>
  </div>

  <% if @alert_thresholds.empty? %>
    <div class="px-4 py-8 text-center text-sm text-naila-text-muted">
      Nenhum limiar cadastrado.
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-naila-border">
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Parâmetro</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Severidade</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Valor</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Escopo</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Cooldown</th>
            <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-naila-text-muted">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-naila-border">
          <% @alert_thresholds.each do |threshold| %>
            <tr class="hover:bg-naila-elevated/50 transition-colors">
              <%# Parâmetro %>
              <td class="px-4 py-3">
                <div class="text-sm font-medium text-naila-text"><%= parameter_labels[threshold.parameter] || threshold.parameter %></div>
                <div class="text-xs text-naila-text-muted"><%= threshold.threshold_type %></div>
              </td>

              <%# Severidade %>
              <td class="px-4 py-3">
                <% severity_classes = case threshold.severity
                                      when 4 then "bg-risk-emergency/20 text-risk-emergency"
                                      when 3 then "bg-risk-high/20 text-risk-high"
                                      when 2 then "bg-risk-alert/20 text-risk-alert"
                                      else "bg-risk-attention/20 text-risk-attention"
                                      end %>
                <% severity_label = case threshold.severity
                                    when 4 then "Emergência"
                                    when 3 then "Alerta Máximo"
                                    when 2 then "Alerta"
                                    else "Atenção"
                                    end %>
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= severity_classes %>">
                  <%= severity_label %>
                </span>
              </td>

              <%# Valor %>
              <td class="px-4 py-3 text-sm tabular-nums text-naila-text">
                <%= comparison_labels[threshold.comparison] || threshold.comparison %> <%= threshold.value %> <%= threshold.unit %>
              </td>

              <%# Escopo %>
              <td class="px-4 py-3 text-sm text-naila-text-muted">
                <% if threshold.river_basin %>
                  <%= threshold.river_basin.name %>
                <% elsif threshold.river %>
                  <%= threshold.river.name %>
                <% else %>
                  <span class="italic">Global</span>
                <% end %>
              </td>

              <%# Status %>
              <td class="px-4 py-3">
                <% if threshold.active? %>
                  <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium bg-risk-normal/20 text-risk-normal">Ativo</span>
                <% else %>
                  <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium bg-naila-elevated text-naila-text-muted">Inativo</span>
                <% end %>
              </td>

              <%# Cooldown %>
              <td class="px-4 py-3 text-sm tabular-nums text-naila-text-muted">
                <%= threshold.cooldown_minutes %> min
              </td>

              <%# Ações %>
              <td class="px-4 py-3 text-right">
                <div class="inline-flex gap-1">
                  <%= link_to admin_alert_threshold_path(threshold),
                        class: "rounded-md p-1.5 text-naila-text-muted hover:bg-naila-elevated hover:text-naila-accent transition-colors",
                        title: "Ver detalhes" do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                  <% end %>

                  <% if policy(threshold).update? %>
                    <%= link_to edit_admin_alert_threshold_path(threshold),
                          class: "rounded-md p-1.5 text-naila-text-muted hover:bg-naila-elevated hover:text-naila-accent transition-colors",
                          title: "Editar" do %>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                      </svg>
                    <% end %>
                  <% end %>

                  <% if policy(threshold).destroy? %>
                    <%= button_to admin_alert_threshold_path(threshold),
                          method: :delete,
                          class: "rounded-md p-1.5 text-naila-text-muted hover:bg-red-500/10 hover:text-red-400 transition-colors",
                          title: "Excluir",
                          form: { data: { turbo_confirm: "Tem certeza que deseja excluir este limiar?" } } do %>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
