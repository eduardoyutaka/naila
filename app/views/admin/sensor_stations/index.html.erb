<% content_for(:title, "Naila — Estações") %>

<%
  online_stations = @sensor_stations.select { |s| s.status == "active" }
  maintenance_stations = @sensor_stations.select { |s| s.status == "maintenance" }
%>

<%# ── Summary Cards ── %>
<div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
  <div class="rounded-xl border border-naila-border bg-naila-surface p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Total de Estações</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-naila-text" data-testid="summary-total-count"><%= @sensor_stations.size %></div>
  </div>
  <div class="rounded-xl border border-naila-border bg-naila-surface p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Online</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sensor-online" data-testid="summary-online-count"><%= online_stations.size %></div>
  </div>
  <div class="rounded-xl border border-naila-border bg-naila-surface p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Em Manutenção</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sensor-degraded" data-testid="summary-maintenance-count"><%= maintenance_stations.size %></div>
  </div>
</div>

<%# ── Sensor Stations Table ── %>
<div class="rounded-xl border border-naila-border bg-naila-surface">
  <div class="flex items-center justify-between border-b border-naila-border px-4 py-3">
    <h2 class="text-sm font-semibold text-naila-text">Estações de Monitoramento</h2>
    <% if policy(SensorStation).create? %>
      <%= link_to new_admin_sensor_station_path,
            class: "inline-flex items-center gap-1.5 rounded-lg bg-naila-accent px-3 py-2 text-xs font-medium text-white transition-colors hover:bg-naila-accent/90" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Nova Estação
      <% end %>
    <% end %>
  </div>

  <% if @sensor_stations.empty? %>
    <div class="px-4 py-8 text-center text-sm text-naila-text-muted">
      Nenhuma estação cadastrada.
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-naila-border">
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Nome</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Sensores</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Localização</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-naila-text-muted">Última Leitura</th>
            <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-naila-text-muted">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-naila-border">
          <% @sensor_stations.each do |station| %>
            <tr class="hover:bg-naila-elevated/50 transition-colors">
              <%# Nome %>
              <td class="px-4 py-3">
                <div class="text-sm font-medium text-naila-text"><%= station.name %></div>
                <div class="text-xs text-naila-text-muted font-mono"><%= station.external_id %></div>
              </td>

              <%# Sensores %>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-1" data-testid="sensor-badges-<%= station.id %>">
                  <% station.sensors.each do |sensor| %>
                    <% type_label = case sensor.sensor_type
                                    when "pluviometer" then "Pluviômetro"
                                    when "river_gauge" then "Fluviômetro"
                                    when "weather_station" then "Meteorológica"
                                    end %>
                    <% type_color = case sensor.sensor_type
                                    when "pluviometer" then "bg-[#3b82f6]/20 text-[#3b82f6]"
                                    when "river_gauge" then "bg-[#06b6d4]/20 text-[#06b6d4]"
                                    when "weather_station" then "bg-[#8b5cf6]/20 text-[#8b5cf6]"
                                    end %>
                    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= type_color %>">
                      <%= type_label %>
                    </span>
                  <% end %>
                  <% if station.sensors.empty? %>
                    <span class="text-xs text-naila-text-muted">—</span>
                  <% end %>
                </div>
              </td>

              <%# Status %>
              <td class="px-4 py-3">
                <% status_label = case station.status
                                  when "active" then "Ativo"
                                  when "maintenance" then "Manutenção"
                                  when "inactive" then "Inativo"
                                  end %>
                <% status_color = case station.status
                                  when "active" then "text-sensor-online"
                                  when "maintenance" then "text-sensor-degraded"
                                  when "inactive" then "text-sensor-offline"
                                  end %>
                <span class="flex items-center gap-1.5 text-xs <%= status_color %>">
                  <span class="inline-block h-1.5 w-1.5 rounded-full bg-current"></span>
                  <%= status_label %>
                </span>
              </td>

              <%# Localização %>
              <td class="px-4 py-3 text-sm text-naila-text-muted">
                <%= station.neighborhood&.name || "—" %>
              </td>

              <%# Última Leitura %>
              <td class="px-4 py-3">
                <% if station.last_reading_value && station.last_reading_at %>
                  <div class="text-sm tabular-nums text-naila-text"><%= number_with_precision(station.last_reading_value, precision: 1) %></div>
                  <div class="text-xs text-naila-text-muted"><%= time_ago_in_words(station.last_reading_at) %> atrás</div>
                <% else %>
                  <span class="text-xs text-naila-text-muted">—</span>
                <% end %>
              </td>

              <%# Ações %>
              <td class="px-4 py-3 text-right">
                <div class="inline-flex items-center gap-1">
                  <%= link_to admin_sensor_station_path(station),
                        class: "rounded-md p-1.5 text-naila-text-muted hover:bg-naila-elevated hover:text-naila-accent transition-colors",
                        title: "Ver detalhes" do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                  <% end %>
                  <% if policy(station).update? %>
                    <%= link_to edit_admin_sensor_station_path(station),
                          class: "rounded-md p-1.5 text-naila-text-muted hover:bg-naila-elevated hover:text-naila-accent transition-colors",
                          title: "Editar" do %>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                      </svg>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
