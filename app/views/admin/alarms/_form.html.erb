<div class="rounded-xl border border-naila-border bg-naila-surface">
  <div class="border-b border-naila-border px-4 py-3">
    <h2 class="text-sm font-semibold text-naila-text">Dados do Alarme</h2>
  </div>

  <div class="p-4 space-y-5">
    <% if alarm.errors.any? %>
      <div class="rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3">
        <p class="text-sm font-medium text-red-400">
          <%= alarm.errors.count %> erro(s) impediu(iram) o salvamento:
        </p>
        <ul class="mt-2 list-disc pl-5 text-sm text-red-400/80">
          <% alarm.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Nome %>
    <div>
      <%= form.label :name, "Nome", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
      <%= form.text_field :name, required: true,
            class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text placeholder-naila-text-muted/50 outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent",
            placeholder: "Ex: Precipitação 3h — Bacia Belém" %>
    </div>

    <%# Tipo + Severidade %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :alarm_type, "Tipo", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.select :alarm_type,
              [["Métrica", "metric"], ["Anomalia", "anomaly_detection"], ["Composto", "composite"]],
              {},
              class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent",
              data: { action: "change->admin--alarm-form#typeChanged" } %>
      </div>
      <div>
        <%= form.label :severity, "Severidade", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.select :severity,
              [["1 — Atenção", 1], ["2 — Alerta", 2], ["3 — Alto", 3], ["4 — Emergência", 4]],
              {},
              class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent" %>
      </div>
    </div>

    <%# Descrição %>
    <div>
      <%= form.label :description, "Descrição", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
      <%= form.text_area :description,
            rows: 2,
            class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text placeholder-naila-text-muted/50 outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent resize-none",
            placeholder: "Descrição opcional..." %>
    </div>

    <%# Escopo %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :river_basin_id, "Bacia Hidrográfica", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.collection_select :river_basin_id, RiverBasin.order(:name), :id, :name,
              { include_blank: "— Nenhuma —" },
              class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent" %>
      </div>
      <div>
        <%= form.label :river_id, "Rio", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
        <%= form.collection_select :river_id, River.order(:name), :id, :name,
              { include_blank: "— Nenhum —" },
              class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent" %>
      </div>
    </div>
    <p class="text-xs text-naila-text-muted -mt-2">Selecione apenas um escopo, ou deixe ambos vazios para escopo global.</p>

    <%# Status %>
    <div>
      <%= form.label :enabled, "Status", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
      <%= form.select :enabled,
            [["Ativado", true], ["Desativado", false]],
            {},
            class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent" %>
    </div>

    <%# ── Metric / Anomaly fields ── %>
    <div data-admin--alarm-form-target="metricFields">
      <div class="border-t border-naila-border pt-5 mt-5">
        <h3 class="text-sm font-semibold text-naila-text mb-4">Configuração de Métrica</h3>

        <div class="space-y-5">
          <%# Metric + Statistic %>
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <%= form.label :metric_name, "Métrica", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
              <%= form.select :metric_name,
                    [["Precipitação 1h", "precipitation_1h"], ["Precipitação 3h", "precipitation_3h"],
                     ["Nível do Rio", "river_level"], ["Score de Risco", "risk_score"],
                     ["Umidade do Solo", "soil_moisture"], ["Previsão Precip.", "forecast_precip"]],
                    { include_blank: "— Selecione —" },
                    class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent" %>
            </div>
            <div>
              <%= form.label :statistic, "Estatística", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
              <%= form.select :statistic,
                    %w[Average Sum Minimum Maximum SampleCount],
                    { include_blank: "— Selecione —" },
                    class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent" %>
            </div>
          </div>

          <%# Period + Evaluation %>
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
            <div>
              <%= form.label :period_seconds, "Período (s)", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
              <%= form.number_field :period_seconds,
                    class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 tabular-nums text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent",
                    min: 60, placeholder: "3600" %>
            </div>
            <div>
              <%= form.label :evaluation_periods, "Períodos de Avaliação", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
              <%= form.number_field :evaluation_periods,
                    class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 tabular-nums text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent",
                    min: 1, placeholder: "3" %>
            </div>
            <div>
              <%= form.label :datapoints_to_alarm, "Datapoints p/ Alarme", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
              <%= form.number_field :datapoints_to_alarm,
                    class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 tabular-nums text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent",
                    min: 1, placeholder: "2" %>
            </div>
          </div>

          <%# Threshold fields (metric only) %>
          <div data-admin--alarm-form-target="thresholdFields">
            <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
              <div>
                <%= form.label :comparison_operator, "Operador", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
                <%= form.select :comparison_operator,
                      [["Maior que", "GreaterThanThreshold"],
                       ["Maior ou igual", "GreaterThanOrEqualToThreshold"],
                       ["Menor que", "LessThanThreshold"],
                       ["Menor ou igual", "LessThanOrEqualToThreshold"]],
                      { include_blank: "— Selecione —" },
                      class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent" %>
              </div>
              <div>
                <%= form.label :threshold_value, "Limiar", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
                <%= form.number_field :threshold_value, step: "any",
                      class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 tabular-nums text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent",
                      placeholder: "40.0" %>
              </div>
              <div>
                <%= form.label :unit, "Unidade", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
                <%= form.text_field :unit,
                      class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent",
                      placeholder: "mm" %>
              </div>
            </div>
          </div>

          <%# Anomaly fields %>
          <div data-admin--alarm-form-target="anomalyFields">
            <div>
              <%= form.label :anomaly_band_width, "Largura da Banda (desvios-padrão)", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
              <%= form.number_field :anomaly_band_width, step: "any",
                    class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 tabular-nums text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent",
                    placeholder: "2.0" %>
            </div>
          </div>

          <%# Missing data %>
          <div>
            <%= form.label :missing_data_treatment, "Tratamento de Dados Ausentes", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
            <%= form.select :missing_data_treatment,
                  [["Ausente", "missing"], ["Não viola", "notBreaching"],
                   ["Viola", "breaching"], ["Ignorar", "ignore"]],
                  {},
                  class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent" %>
          </div>
        </div>
      </div>
    </div>

    <%# ── Composite fields ── %>
    <div data-admin--alarm-form-target="compositeFields">
      <div class="border-t border-naila-border pt-5 mt-5">
        <h3 class="text-sm font-semibold text-naila-text mb-4">Configuração Composta</h3>

        <div class="space-y-5">
          <div>
            <%= form.label :composite_rule, "Regra Composta", class: "mb-1.5 block text-sm font-medium text-naila-text-muted" %>
            <%= form.text_area :composite_rule,
                  rows: 3,
                  class: "w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 font-mono text-sm text-naila-text placeholder-naila-text-muted/50 outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent resize-none",
                  placeholder: "ALARM(Nome do Alarme 1) AND ALARM(Nome do Alarme 2)" %>
            <p class="mt-1.5 text-xs text-naila-text-muted">
              Use ALARM(nome), OK(nome), INSUFFICIENT_DATA(nome) com operadores AND, OR, NOT e parênteses.
            </p>
          </div>
          <div>
            <label class="flex items-center gap-2">
              <%= form.check_box :suppress_child_actions,
                    class: "rounded border-naila-border bg-naila-elevated text-naila-accent focus:ring-naila-accent" %>
              <span class="text-sm text-naila-text-muted">Suprimir ações dos alarmes filhos</span>
            </label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center justify-end gap-3 border-t border-naila-border px-4 py-3">
    <%= link_to "Cancelar", admin_alarms_path, class: "text-sm text-naila-text-muted hover:text-naila-text transition-colors" %>
    <%= form.submit alarm.persisted? ? "Salvar" : "Criar Alarme",
          class: "rounded-lg bg-naila-accent px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-naila-accent/90 focus:outline-none focus:ring-2 focus:ring-naila-accent focus:ring-offset-2 focus:ring-offset-naila-bg cursor-pointer" %>
  </div>
</div>
