<% content_for(:title, "Naila — Editar Alarme") %>

<div class="mx-auto max-w-3xl" data-controller="admin--alarm-form"
     data-admin--alarm-form-type-value="<%= @alarm.alarm_type %>">
  <div class="mb-4">
    <%= link_to admin_alarm_path(@alarm), class: "inline-flex items-center gap-1 text-sm text-zinc-400 hover:text-sky-500 transition-colors" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
      </svg>
      Voltar ao alarme
    <% end %>
  </div>
  <div class="mb-6">
    <h1 class="text-xl font-semibold text-white">Editar Alarme</h1>
  </div>

  <%= form_with model: [:admin, @alarm] do |f| %>
    <%= render "form", form: f, alarm: @alarm %>
  <% end %>
</div>
