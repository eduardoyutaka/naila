<% content_for(:title, "Naila — #{@alarm.name}") %>

<%
  state_label = { "ok" => "OK", "alarm" => "Alarme", "insufficient_data" => "Dados Insuficientes" }
  state_color = {
    "ok"                => "bg-risk-normal/20 text-risk-normal",
    "alarm"             => "bg-risk-high/20 text-risk-high",
    "insufficient_data" => "bg-naila-elevated text-naila-text-muted"
  }
  type_label = { "metric" => "Métrica", "anomaly_detection" => "Anomalia", "composite" => "Composto" }
  trigger_label = { "alarm" => "Alarme", "ok" => "OK", "insufficient_data" => "Dados Insuficientes" }
%>

<%# ── Back Link ── %>
<div class="mb-4">
  <%= link_to admin_alarms_path, class: "inline-flex items-center gap-1 text-sm text-naila-text-muted hover:text-naila-accent transition-colors" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
    </svg>
    Voltar aos alarmes
  <% end %>
</div>

<%# ── Header ── %>
<div class="mb-6">
  <div class="flex flex-wrap items-center gap-2 mb-2">
    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= state_color[@alarm.state] %>" data-testid="alarm-state">
      <%= state_label[@alarm.state] %>
    </span>
    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium bg-naila-elevated text-naila-text-muted">
      <%= type_label[@alarm.alarm_type] %>
    </span>
    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium bg-naila-elevated text-naila-text-muted">
      Severidade <%= @alarm.severity %>
    </span>
    <% unless @alarm.enabled? %>
      <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium bg-risk-attention/20 text-risk-attention">
        Desativado
      </span>
    <% end %>
  </div>
  <h1 class="text-xl font-semibold text-naila-text"><%= @alarm.name %></h1>
  <% if @alarm.description.present? %>
    <p class="mt-1 text-sm text-naila-text-muted"><%= @alarm.description %></p>
  <% end %>
</div>

<div class="grid gap-6 lg:grid-cols-3">
  <%# ── Left Column ── %>
  <div class="lg:col-span-2 space-y-6">

    <%# Configuration %>
    <div class="rounded-xl border border-naila-border bg-naila-surface" data-testid="alarm-config">
      <div class="border-b border-naila-border px-4 py-3">
        <h2 class="text-sm font-semibold text-naila-text">Configuração</h2>
      </div>
      <div class="divide-y divide-naila-border">
        <% if @alarm.metric? || @alarm.anomaly_detection? %>
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Métrica</span>
            <span class="text-sm text-naila-text"><%= @alarm.metric_name %></span>
          </div>
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Estatística</span>
            <span class="text-sm text-naila-text"><%= @alarm.statistic %></span>
          </div>
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Período</span>
            <span class="text-sm tabular-nums text-naila-text"><%= @alarm.period_seconds %>s</span>
          </div>
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Avaliação</span>
            <span class="text-sm tabular-nums text-naila-text"><%= @alarm.datapoints_to_alarm %> de <%= @alarm.evaluation_periods %> períodos</span>
          </div>
          <% if @alarm.metric? %>
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Limiar</span>
              <span class="text-sm tabular-nums text-naila-text"><%= @alarm.comparison_operator&.gsub(/([A-Z])/, ' \1')&.strip %> <%= @alarm.threshold_value %> <%= @alarm.unit %></span>
            </div>
          <% end %>
          <% if @alarm.anomaly_detection? %>
            <div class="flex items-center justify-between px-4 py-3">
              <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Banda de Anomalia</span>
              <span class="text-sm tabular-nums text-naila-text"><%= @alarm.anomaly_band_width %> desvios-padrão</span>
            </div>
          <% end %>
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Dados Ausentes</span>
            <span class="text-sm text-naila-text"><%= @alarm.missing_data_treatment %></span>
          </div>
        <% elsif @alarm.composite? %>
          <div class="px-4 py-3">
            <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Regra Composta</span>
            <div class="mt-2 rounded-lg bg-naila-elevated px-3 py-2 font-mono text-sm text-naila-text">
              <%= @alarm.composite_rule %>
            </div>
          </div>
          <div class="flex items-center justify-between px-4 py-3">
            <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Suprimir Ações dos Filhos</span>
            <span class="text-sm text-naila-text"><%= @alarm.suppress_child_actions? ? "Sim" : "Não" %></span>
          </div>
        <% end %>
        <div class="flex items-center justify-between px-4 py-3">
          <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Escopo</span>
          <span class="text-sm text-naila-text"><%= @alarm.river&.name || @alarm.river_basin&.name || "Global" %></span>
        </div>
        <% if @alarm.state_reason.present? %>
          <div class="px-4 py-3">
            <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Razão do Estado</span>
            <div class="mt-1 text-sm text-naila-text-muted"><%= @alarm.state_reason %></div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Alarm Actions %>
    <div class="rounded-xl border border-naila-border bg-naila-surface" data-testid="alarm-actions">
      <div class="flex items-center justify-between border-b border-naila-border px-4 py-3">
        <h2 class="text-sm font-semibold text-naila-text">Ações</h2>
        <% if policy(AlarmAction).create? %>
          <%= link_to new_admin_alarm_alarm_action_path(@alarm),
                class: "inline-flex items-center gap-1.5 rounded-lg bg-naila-accent px-3 py-2 text-xs font-medium text-white transition-colors hover:bg-naila-accent/90" do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Nova Ação
          <% end %>
        <% end %>
      </div>
      <% if @alarm_actions.empty? %>
        <div class="px-4 py-6 text-center text-sm text-naila-text-muted">
          Nenhuma ação configurada.
        </div>
      <% else %>
        <div class="divide-y divide-naila-border">
          <% @alarm_actions.each do |action| %>
            <div class="flex items-center justify-between px-4 py-3">
              <div class="flex items-center gap-3">
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= state_color[action.trigger_state] %>">
                  <%= trigger_label[action.trigger_state] %>
                </span>
                <span class="text-sm text-naila-text"><%= action.action_type.titleize %></span>
                <% unless action.enabled? %>
                  <span class="text-xs text-naila-text-muted">(desativada)</span>
                <% end %>
              </div>
              <div class="inline-flex items-center gap-1">
                <% if policy(action).update? %>
                  <%= link_to edit_admin_alarm_alarm_action_path(@alarm, action),
                        class: "rounded-md p-1.5 text-naila-text-muted hover:bg-naila-elevated hover:text-naila-accent transition-colors",
                        title: "Editar" do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                    </svg>
                  <% end %>
                <% end %>
                <% if policy(action).destroy? %>
                  <%= button_to admin_alarm_alarm_action_path(@alarm, action),
                        method: :delete,
                        class: "rounded-md p-1.5 text-naila-text-muted hover:bg-naila-elevated hover:text-risk-high transition-colors",
                        title: "Remover",
                        form: { data: { turbo_confirm: "Remover esta ação?" } } do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Child Alarms (Composite only) %>
    <% if @alarm.composite? && @child_alarms.any? %>
      <div class="rounded-xl border border-naila-border bg-naila-surface">
        <div class="border-b border-naila-border px-4 py-3">
          <h2 class="text-sm font-semibold text-naila-text">Alarmes Filhos</h2>
        </div>
        <div class="divide-y divide-naila-border">
          <% @child_alarms.each do |child| %>
            <div class="flex items-center justify-between px-4 py-3">
              <div class="flex items-center gap-2">
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= state_color[child.state] %>">
                  <%= state_label[child.state] %>
                </span>
                <%= link_to child.name, admin_alarm_path(child), class: "text-sm text-naila-accent hover:underline" %>
              </div>
              <span class="text-xs text-naila-text-muted"><%= type_label[child.alarm_type] %></span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# State History %>
    <% if @state_histories.any? %>
      <div class="rounded-xl border border-naila-border bg-naila-surface" data-testid="alarm-history">
        <div class="flex items-center justify-between border-b border-naila-border px-4 py-3">
          <h2 class="text-sm font-semibold text-naila-text">Histórico de Estados</h2>
          <%= link_to "Ver tudo", history_admin_alarm_path(@alarm),
                class: "text-xs text-naila-accent hover:underline" %>
        </div>
        <div class="divide-y divide-naila-border">
          <% @state_histories.each do |history| %>
            <div class="px-4 py-3">
              <div class="flex items-center gap-2 mb-1">
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= state_color[history.previous_state] %>">
                  <%= state_label[history.previous_state] %>
                </span>
                <svg class="h-3 w-3 text-naila-text-muted" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= state_color[history.new_state] %>">
                  <%= state_label[history.new_state] %>
                </span>
                <span class="text-xs tabular-nums text-naila-text-muted ml-auto">
                  <%= history.evaluated_at.strftime("%d/%m/%Y %H:%M") %>
                </span>
              </div>
              <div class="text-xs text-naila-text-muted"><%= history.reason %></div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>

  <%# ── Right Column ── %>
  <div class="space-y-6">

    <%# Actions %>
    <div class="rounded-xl border border-naila-border bg-naila-surface">
      <div class="border-b border-naila-border px-4 py-3">
        <h2 class="text-sm font-semibold text-naila-text">Ações</h2>
      </div>
      <div class="p-4 space-y-3">
        <% if policy(@alarm).update? %>
          <%= link_to edit_admin_alarm_path(@alarm),
                class: "flex w-full items-center justify-center gap-2 rounded-lg border border-naila-border bg-naila-elevated px-4 py-2.5 text-sm font-medium text-naila-text transition-colors hover:border-naila-accent hover:text-naila-accent" do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
            </svg>
            Editar Alarme
          <% end %>
        <% end %>
        <% if policy(@alarm).enable? && !@alarm.enabled? %>
          <%= button_to enable_admin_alarm_path(@alarm),
                method: :patch,
                class: "flex w-full items-center justify-center gap-2 rounded-lg border border-risk-normal/30 bg-risk-normal/10 px-4 py-2.5 text-sm font-medium text-risk-normal transition-colors hover:bg-risk-normal/20" do %>
            Ativar Alarme
          <% end %>
        <% end %>
        <% if policy(@alarm).disable? && @alarm.enabled? %>
          <%= button_to disable_admin_alarm_path(@alarm),
                method: :patch,
                class: "flex w-full items-center justify-center gap-2 rounded-lg border border-risk-attention/30 bg-risk-attention/10 px-4 py-2.5 text-sm font-medium text-risk-attention transition-colors hover:bg-risk-attention/20" do %>
            Desativar Alarme
          <% end %>
        <% end %>
        <% if policy(@alarm).destroy? %>
          <%= button_to admin_alarm_path(@alarm),
                method: :delete,
                class: "flex w-full items-center justify-center gap-2 rounded-lg border border-risk-high/30 bg-risk-high/10 px-4 py-2.5 text-sm font-medium text-risk-high transition-colors hover:bg-risk-high/20",
                form: { data: { turbo_confirm: "Tem certeza que deseja remover este alarme? Esta ação não pode ser desfeita." } } do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
            Remover Alarme
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Quick Stats %>
    <div class="rounded-xl border border-naila-border bg-naila-surface">
      <div class="border-b border-naila-border px-4 py-3">
        <h2 class="text-sm font-semibold text-naila-text">Informações</h2>
      </div>
      <div class="divide-y divide-naila-border">
        <div class="flex items-center justify-between px-4 py-3">
          <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Última Avaliação</span>
          <span class="text-sm tabular-nums text-naila-text">
            <%= @alarm.last_evaluated_at ? l(@alarm.last_evaluated_at, format: :short) : "—" %>
          </span>
        </div>
        <div class="flex items-center justify-between px-4 py-3">
          <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Mudança de Estado</span>
          <span class="text-sm tabular-nums text-naila-text">
            <%= @alarm.state_changed_at ? l(@alarm.state_changed_at, format: :short) : "—" %>
          </span>
        </div>
        <div class="flex items-center justify-between px-4 py-3">
          <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Total de Transições</span>
          <span class="text-sm tabular-nums text-naila-text"><%= @alarm.alarm_state_histories.count %></span>
        </div>
        <div class="flex items-center justify-between px-4 py-3">
          <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Criado em</span>
          <span class="text-sm tabular-nums text-naila-text"><%= @alarm.created_at.strftime("%d/%m/%Y") %></span>
        </div>
      </div>
    </div>

  </div>
</div>
