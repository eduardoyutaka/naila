<% content_for(:title, "Naila — Painel de Monitoramento") %>

<%= catalyst_heading "Painel de Monitoramento", level: 1, class: "mb-8" %>

<%# ── Summary Cards ── %>
<div class="mb-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
  <div class="rounded-xl border border-white/10 bg-zinc-800/50 p-4">
    <div class="text-sm font-semibold uppercase tracking-wider text-zinc-300">Sensores Online</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sensor-online"><%= @sensors_online %></div>
  </div>
  <% RiskHelper::SEVERITY_LABEL.each do |severity, label| %>
    <div class="rounded-xl border border-white/10 border-l-4 bg-zinc-800/50 p-4 <%= RiskHelper::SEVERITY_BORDER_CLASS[severity] %>">
      <div class="text-sm font-semibold uppercase tracking-wider text-zinc-300"><%= label %></div>
      <div class="mt-2 text-3xl font-semibold tabular-nums <%= RiskHelper::SEVERITY_TEXT_CLASS[severity] %>">
        <%= @alarms_by_severity.fetch(severity, 0) %>
      </div>
    </div>
  <% end %>
  <div class="rounded-xl border border-white/10 bg-zinc-800/50 p-4">
    <div class="text-sm font-semibold uppercase tracking-wider text-zinc-300">Bacias Monitoradas</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sky-500"><%= @river_basins.size %></div>
  </div>
</div>

<%# ── Weather Summary ── %>
<%= render "admin/dashboard/weather_summary",
    current_weather: @current_weather,
    forecast_summary: @forecast_summary %>

<%# ── Map ── %>
<%= turbo_stream_from "basin_alarms" %>
<div class="mb-6 overflow-hidden rounded-xl border border-white/10 bg-zinc-900"
     data-controller="admin--map"
     data-admin--map-river-basins-value="<%= @river_basins.map { |b|
       {
         id: b.id,
         name: b.name,
         risk_level: b.current_risk_level,
         alert_severity: @active_alarm_severity_by_basin[b.id],
         geometry: b.geometry ? RGeo::GeoJSON.encode(b.geometry) : nil
       }
     }.to_json %>"
     data-admin--map-sensors-value="<%= @monitoring_stations.map { |s|
       {
         id: s.id,
         name: s.name,
         sensor_types: s.sensors.map(&:sensor_type),
         status: s.status,
         lat: s.location&.y,
         lng: s.location&.x,
         neighborhood: s.neighborhood&.name,
         river: s.river&.name,
         last_reading_at: s.last_reading_at&.iso8601,
         last_reading_value: s.last_reading_value
       }
     }.to_json %>"
     data-admin--map-center-value="[-49.2733, -25.4284]"
     data-admin--map-zoom-value="12"
     data-admin--map-admin--side-sheet-outlet="#sensor-side-sheet">
  <div class="flex flex-wrap items-center justify-between gap-2 border-b border-white/10 px-4 py-3">
    <h2 class="text-sm font-semibold text-white">Mapa de Risco — Curitiba</h2>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-zinc-400">
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-full bg-risk-normal"></span> Normal</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-full bg-risk-attention"></span> Atenção</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-full bg-risk-alert"></span> Alerta</span>
      <span class="flex items-center gap-1">
        <svg class="h-2.5 w-2.5 text-risk-high" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M8 2L14.9 14H1.1z"/></svg>
        Alerta Máx
      </span>
      <span class="flex items-center gap-1">
        <span class="inline-block h-2.5 w-2.5 rotate-45 bg-risk-emergency"></span>
        Emergência
      </span>
      <span class="h-3 w-px bg-white/10" aria-hidden="true"></span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-sm bg-sensor-pluviometer"></span> Pluviômetro</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-full bg-sensor-river-gauge"></span> Fluviômetro</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rotate-45 bg-sensor-weather"></span> Meteorológica</span>
    </div>
  </div>
  <div id="basin-alarm-severities"
       data-admin--map-target="alertSeverities"
       class="hidden"
       data-value="<%= @active_alarm_severity_by_basin.to_json %>"></div>
  <div data-admin--map-target="canvas" class="h-[480px] w-full"></div>
</div>

<%# ── Sensor Side Sheet ── %>
<div id="sensor-side-sheet"
     data-controller="admin--side-sheet"
     data-action="keydown.esc@document->admin--side-sheet#close"
     class="hidden">
  <div data-action="click->admin--side-sheet#close"
       class="fixed inset-0 z-40 bg-black/30"></div>
  <div data-admin--side-sheet-target="panel"
       class="fixed right-0 top-14 bottom-0 z-50 w-96 overflow-y-auto border-l border-white/10 bg-zinc-900 shadow-2xl animate-slide-in-right">
    <turbo-frame id="sensor_detail" data-admin--side-sheet-target="frame" loading="lazy">
    </turbo-frame>
  </div>
</div>

<%# ── Bottom panels ── %>
<div class="grid gap-6 lg:grid-cols-2">
  <%# Active Alarms %>
  <div class="rounded-xl border border-white/10 bg-zinc-900">
    <div class="flex items-center justify-between border-b border-white/10 px-4 py-3">
      <h2 class="text-sm font-semibold text-white">Alarmes Ativos</h2>
      <span class="text-xs text-zinc-400"><%= @active_alarms.size %> alarme(s)</span>
    </div>
    <div class="divide-y divide-white/10">
      <% if @active_alarms.empty? %>
        <div class="px-4 py-8 text-center text-sm text-zinc-400">
          Nenhum alarme ativo no momento.
        </div>
      <% else %>
        <% @active_alarms.each do |alarm| %>
          <div class="flex items-start gap-3 px-4 py-3">
            <div class="mt-1 flex-shrink-0 h-4 w-4 flex items-center justify-center" aria-hidden="true">
              <% case alarm.current_severity
                 when 4 %>
                <%# Diamond — emergency %>
                <svg class="h-3.5 w-3.5 text-risk-emergency glow-emergency animate-pulse-slow" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M8 1l3 6H5z M8 15l-3-6h6z M1 8l6-3v6z M15 8l-6 3V5z"/>
                </svg>
              <% when 3 %>
                <%# Triangle — high alert %>
                <svg class="h-3.5 w-3.5 text-risk-high" fill="currentColor" viewBox="0 0 16 16">
                  <path d="M8 2L14.9 14H1.1L8 2z"/>
                </svg>
              <% else %>
                <%# Circle — attention / alert %>
                <% dot_class = alarm.current_severity == 2 ? "bg-risk-alert glow-alert" : "bg-risk-attention glow-attention" %>
                <span class="h-3 w-3 rounded-full <%= dot_class %>"></span>
              <% end %>
            </div>
            <span class="sr-only"><%= RiskHelper::SEVERITY_LABEL[alarm.current_severity] %>:</span>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <%= link_to alarm.name, admin_alarm_path(alarm), class: "text-sm font-medium text-white truncate hover:text-sky-500" %>
                <%= severity_badge(alarm.current_severity) %>
              </div>
              <p class="mt-0.5 text-xs text-zinc-400 truncate"><%= alarm.state_reason %></p>
              <div class="mt-1 text-xs text-zinc-400">
                <%= time_ago_in_words(alarm.state_changed_at) %> atrás
                <% if alarm.river_basin %>
                  · <span class="text-sky-500"><%= alarm.river_basin.name %></span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Recent Readings %>
  <div class="rounded-xl border border-white/10 bg-zinc-900">
    <div class="flex items-center justify-between border-b border-white/10 px-4 py-3">
      <h2 class="text-sm font-semibold text-white">Leituras Recentes</h2>
      <span class="text-xs text-zinc-400">Últimas 10</span>
    </div>
    <div class="divide-y divide-white/10">
      <% if @recent_readings.empty? %>
        <div class="px-4 py-8 text-center text-sm text-zinc-400">
          Nenhuma leitura recente disponível.
        </div>
      <% else %>
        <% @recent_readings.each do |reading| %>
          <div class="flex items-center justify-between px-4 py-2.5">
            <div class="flex items-center gap-3 min-w-0">
              <span class="flex-shrink-0 text-zinc-400">
                <% case reading.reading_type %>
                <% when "precipitation" %>
                  <%# Droplet %>
                  <svg class="h-4 w-4 text-sensor-pluviometer" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c0 0-7 7.5-7 11.5a7 7 0 0 0 14 0C19 10.5 12 3 12 3Z" />
                  </svg>
                <% when "river_level" %>
                  <%# Waves %>
                  <svg class="h-4 w-4 text-sensor-river-gauge" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 14.5c1.5 0 2.5-1 4-1s2.5 1 4 1 2.5-1 4-1 2.5 1 4 1M3 18.5c1.5 0 2.5-1 4-1s2.5 1 4 1 2.5-1 4-1 2.5 1 4 1M3 10.5c1.5 0 2.5-1 4-1s2.5 1 4 1 2.5-1 4-1 2.5 1 4 1" />
                  </svg>
                <% when "temperature" %>
                  <%# Thermometer %>
                  <svg class="h-4 w-4 text-sensor-weather" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 9.75a3 3 0 1 1-6 0V5.25a3 3 0 0 1 6 0v4.5ZM12 17.25a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                  </svg>
                <% when "humidity" %>
                  <%# Wind %>
                  <svg class="h-4 w-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8.25h12a3 3 0 1 1-3 3M3 15.75h9a3 3 0 1 0-3-3" />
                  </svg>
                <% else %>
                  <%# Signal / antenna %>
                  <%= render "shared/icons/signal" %>
                <% end %>
              </span>
              <div class="min-w-0">
                <div class="text-sm font-medium text-white truncate"><%= reading.monitoring_station&.name || "—" %></div>
                <div class="text-xs text-zinc-400"><%= reading.reading_type&.humanize %></div>
              </div>
            </div>
            <div class="text-right flex-shrink-0 ml-3">
              <div class="text-sm font-semibold tabular-nums text-white"><%= number_with_precision(reading.value, precision: 1) %> <span class="text-zinc-400 font-normal"><%= reading.unit %></span></div>
              <div class="text-xs text-zinc-400 tabular-nums"><%= reading.recorded_at&.strftime("%H:%M") %></div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
