<% content_for(:title, "Naila — Painel de Monitoramento") %>

<%# ── Summary Cards ── %>
<div class="mb-6 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
  <div class="rounded-xl border border-naila-border bg-naila-surface p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Sensores Online</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sensor-online"><%= @sensors_online %></div>
  </div>
  <% [
    [1, "Atenção",       "text-risk-attention"],
    [2, "Alerta",        "text-risk-alert"],
    [3, "Alerta Máximo", "text-risk-high"],
    [4, "Emergência",    "text-risk-emergency"],
  ].each do |severity, label, color| %>
    <div class="rounded-xl border border-naila-border bg-naila-surface p-4">
      <div class="text-xs font-medium uppercase tracking-wider text-naila-text-muted"><%= label %></div>
      <div class="mt-2 text-3xl font-semibold tabular-nums <%= color %>">
        <%= @alarms_by_severity.fetch(severity, 0) %>
      </div>
    </div>
  <% end %>
  <div class="rounded-xl border border-naila-border bg-naila-surface p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Bacias Monitoradas</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-naila-accent"><%= @river_basins.size %></div>
  </div>
</div>

<%# ── Weather Summary ── %>
<%= render "admin/dashboard/weather_summary",
    current_weather: @current_weather,
    forecast_summary: @forecast_summary %>

<%# ── Map ── %>
<%= turbo_stream_from "basin_alarms" %>
<div class="mb-6 overflow-hidden rounded-xl border border-naila-border bg-naila-surface"
     data-controller="admin--map"
     data-admin--map-river-basins-value="<%= @river_basins.map { |b|
       {
         id: b.id,
         name: b.name,
         risk_level: b.current_risk_level,
         alert_severity: @active_alarm_severity_by_basin[b.id],
         geometry: b.geometry ? RGeo::GeoJSON.encode(b.geometry) : nil
       }
     }.to_json %>"
     data-admin--map-sensors-value="<%= @monitoring_stations.map { |s|
       {
         id: s.id,
         name: s.name,
         sensor_types: s.sensors.map(&:sensor_type),
         status: s.status,
         lat: s.location&.y,
         lng: s.location&.x,
         neighborhood: s.neighborhood&.name,
         river: s.river&.name,
         last_reading_at: s.last_reading_at&.iso8601,
         last_reading_value: s.last_reading_value
       }
     }.to_json %>"
     data-admin--map-center-value="[-49.2733, -25.4284]"
     data-admin--map-zoom-value="12"
     data-admin--map-admin--side-sheet-outlet="#sensor-side-sheet">
  <div class="flex flex-wrap items-center justify-between gap-2 border-b border-naila-border px-4 py-3">
    <h2 class="text-sm font-semibold text-naila-text">Mapa de Risco — Curitiba</h2>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-naila-text-muted">
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-full bg-risk-normal"></span> Normal</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-full bg-risk-attention"></span> Atenção</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-full bg-risk-alert"></span> Alerta</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-full bg-risk-high"></span> Alerta Máx</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-full bg-risk-emergency"></span> Emergência</span>
      <span class="text-naila-border">|</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-sm bg-[#3b82f6]"></span> Pluviômetro</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rounded-full bg-[#06b6d4]"></span> Fluviômetro</span>
      <span class="flex items-center gap-1"><span class="inline-block h-2.5 w-2.5 rotate-45 bg-[#8b5cf6]"></span> Meteorológica</span>
    </div>
  </div>
  <div id="basin-alarm-severities"
       data-admin--map-target="alertSeverities"
       class="hidden"
       data-value="<%= @active_alarm_severity_by_basin.to_json %>"></div>
  <div data-admin--map-target="canvas" class="h-[480px] w-full"></div>
</div>

<%# ── Sensor Side Sheet ── %>
<div id="sensor-side-sheet"
     data-controller="admin--side-sheet"
     data-action="keydown.esc@document->admin--side-sheet#close"
     class="hidden">
  <div data-action="click->admin--side-sheet#close"
       class="fixed inset-0 z-40 bg-black/30"></div>
  <div data-admin--side-sheet-target="panel"
       class="fixed right-0 top-14 bottom-0 z-50 w-96 overflow-y-auto border-l border-naila-border bg-naila-surface shadow-2xl animate-slide-in-right">
    <turbo-frame id="sensor_detail" data-admin--side-sheet-target="frame" loading="lazy">
    </turbo-frame>
  </div>
</div>

<%# ── Bottom panels ── %>
<div class="grid gap-6 lg:grid-cols-2">
  <%# Active Alarms %>
  <div class="rounded-xl border border-naila-border bg-naila-surface">
    <div class="flex items-center justify-between border-b border-naila-border px-4 py-3">
      <h2 class="text-sm font-semibold text-naila-text">Alarmes Ativos</h2>
      <span class="text-xs text-naila-text-muted"><%= @active_alarms.size %> alarme(s)</span>
    </div>
    <div class="divide-y divide-naila-border">
      <% if @active_alarms.empty? %>
        <div class="px-4 py-8 text-center text-sm text-naila-text-muted">
          Nenhum alarme ativo no momento.
        </div>
      <% else %>
        <% @active_alarms.each do |alarm| %>
          <div class="flex items-start gap-3 px-4 py-3">
            <% severity_color = case alarm.severity
                                when 4 then "bg-risk-emergency glow-emergency"
                                when 3 then "bg-risk-high glow-high"
                                when 2 then "bg-risk-alert glow-alert"
                                else "bg-risk-attention glow-attention"
                                end %>
            <div class="mt-1 h-3 w-3 flex-shrink-0 rounded-full <%= severity_color %>"></div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <%= link_to alarm.name, admin_alarm_path(alarm), class: "text-sm font-medium text-naila-text truncate hover:text-naila-accent" %>
                <% severity_label = case alarm.severity
                                    when 4 then "Emergência"
                                    when 3 then "Alerta Máximo"
                                    when 2 then "Alerta"
                                    else "Atenção"
                                    end %>
                <span class="flex-shrink-0 rounded px-1.5 py-0.5 text-xs font-medium
                  <%= case alarm.severity
                      when 4 then 'bg-risk-emergency/20 text-risk-emergency'
                      when 3 then 'bg-risk-high/20 text-risk-high'
                      when 2 then 'bg-risk-alert/20 text-risk-alert'
                      else 'bg-risk-attention/20 text-risk-attention'
                      end %>">
                  <%= severity_label %>
                </span>
              </div>
              <p class="mt-0.5 text-xs text-naila-text-muted truncate"><%= alarm.state_reason %></p>
              <div class="mt-1 text-xs text-naila-text-muted">
                <%= time_ago_in_words(alarm.state_changed_at) %> atrás
                <% if alarm.river_basin %>
                  · <span class="text-naila-accent"><%= alarm.river_basin.name %></span>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Recent Readings %>
  <div class="rounded-xl border border-naila-border bg-naila-surface">
    <div class="flex items-center justify-between border-b border-naila-border px-4 py-3">
      <h2 class="text-sm font-semibold text-naila-text">Leituras Recentes</h2>
      <span class="text-xs text-naila-text-muted">Últimas 10</span>
    </div>
    <div class="divide-y divide-naila-border">
      <% if @recent_readings.empty? %>
        <div class="px-4 py-8 text-center text-sm text-naila-text-muted">
          Nenhuma leitura recente disponível.
        </div>
      <% else %>
        <% @recent_readings.each do |reading| %>
          <div class="flex items-center justify-between px-4 py-2.5">
            <div class="flex items-center gap-3 min-w-0">
              <% reading_icon = case reading.reading_type
                                when "precipitation" then "💧"
                                when "river_level" then "🌊"
                                when "temperature" then "🌡️"
                                when "humidity" then "💨"
                                else "📡"
                                end %>
              <span class="text-sm"><%= reading_icon %></span>
              <div class="min-w-0">
                <div class="text-sm font-medium text-naila-text truncate"><%= reading.monitoring_station&.name || "—" %></div>
                <div class="text-xs text-naila-text-muted"><%= reading.reading_type&.humanize %></div>
              </div>
            </div>
            <div class="text-right flex-shrink-0 ml-3">
              <div class="text-sm font-semibold tabular-nums text-naila-text"><%= number_with_precision(reading.value, precision: 1) %> <span class="text-naila-text-muted font-normal"><%= reading.unit %></span></div>
              <div class="text-xs text-naila-text-muted tabular-nums"><%= reading.recorded_at&.strftime("%H:%M") %></div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
