<div class="rounded-xl border border-naila-border bg-naila-surface" data-testid="weather-context">
  <div class="border-b border-naila-border px-4 py-3">
    <h2 class="text-sm font-semibold text-naila-text">Contexto Meteorológico</h2>
  </div>
  <div class="divide-y divide-naila-border">
    <% if current_weather %>
      <div class="flex items-center justify-between px-4 py-3">
        <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Temperatura</span>
        <span class="text-sm tabular-nums text-naila-text">
          <%= current_weather.temperature_c ? "#{number_with_precision(current_weather.temperature_c, precision: 1)}°C" : "—" %>
        </span>
      </div>
      <div class="flex items-center justify-between px-4 py-3">
        <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Umidade</span>
        <span class="text-sm tabular-nums text-naila-text">
          <%= current_weather.humidity_pct ? "#{number_with_precision(current_weather.humidity_pct, precision: 0)}%" : "—" %>
        </span>
      </div>
      <% if current_weather.precipitation_mm %>
        <div class="flex items-center justify-between px-4 py-3">
          <span class="text-xs font-medium uppercase tracking-wider text-naila-text-muted">Precipitação atual</span>
          <span class="text-sm tabular-nums text-naila-text">
            <%= "#{number_with_precision(current_weather.precipitation_mm, precision: 1)} mm" %>
          </span>
        </div>
      <% end %>
    <% end %>

    <div class="px-4 py-3">
      <div class="text-xs font-medium uppercase tracking-wider text-naila-text-muted mb-2">Previsão 6h</div>
      <div class="grid grid-cols-2 gap-2">
        <div class="flex items-center justify-between rounded-md bg-naila-elevated px-2 py-1.5">
          <span class="text-xs text-naila-text-muted">Total</span>
          <span class="text-xs tabular-nums text-naila-text ml-2"><%= number_with_precision(forecast_summary[:total_precipitation_mm], precision: 1) %> mm</span>
        </div>
        <div class="flex items-center justify-between rounded-md bg-naila-elevated px-2 py-1.5">
          <span class="text-xs text-naila-text-muted">Prob. máx.</span>
          <span class="text-xs tabular-nums text-naila-text ml-2"><%= number_with_precision(forecast_summary[:max_probability], precision: 0) %>%</span>
        </div>
      </div>
    </div>

    <div class="px-4 py-3">
      <%= link_to admin_weather_path,
            class: "flex w-full items-center justify-center gap-2 rounded-lg border border-naila-border bg-naila-elevated px-4 py-2 text-xs font-medium text-naila-text-muted transition-colors hover:border-naila-accent hover:text-naila-accent" do %>
        Ver meteorologia completa →
      <% end %>
    </div>
  </div>
</div>
