<div class="rounded-xl border border-white/10 bg-zinc-900" data-testid="weather-context">
  <div class="border-b border-white/10 px-4 py-3">
    <h2 class="text-sm font-semibold text-white">Contexto Meteorológico</h2>
  </div>
  <div class="divide-y divide-white/10">
    <% if current_weather %>
      <div class="flex items-center justify-between px-4 py-3">
        <span class="text-xs font-medium uppercase tracking-wider text-zinc-400">Temperatura</span>
        <span class="text-sm tabular-nums text-white">
          <%= current_weather.temperature_c ? "#{number_with_precision(current_weather.temperature_c, precision: 1)}°C" : "—" %>
        </span>
      </div>
      <div class="flex items-center justify-between px-4 py-3">
        <span class="text-xs font-medium uppercase tracking-wider text-zinc-400">Umidade</span>
        <span class="text-sm tabular-nums text-white">
          <%= current_weather.humidity_pct ? "#{number_with_precision(current_weather.humidity_pct, precision: 0)}%" : "—" %>
        </span>
      </div>
      <% if current_weather.precipitation_mm %>
        <div class="flex items-center justify-between px-4 py-3">
          <span class="text-xs font-medium uppercase tracking-wider text-zinc-400">Precipitação atual</span>
          <span class="text-sm tabular-nums text-white">
            <%= "#{number_with_precision(current_weather.precipitation_mm, precision: 1)} mm" %>
          </span>
        </div>
      <% end %>
    <% end %>

    <div class="px-4 py-3">
      <div class="text-xs font-medium uppercase tracking-wider text-zinc-400 mb-2">Previsão 6h</div>
      <div class="grid grid-cols-2 gap-2">
        <div class="flex items-center justify-between rounded-md bg-zinc-800 px-2 py-1.5">
          <span class="text-xs text-zinc-400">Total</span>
          <span class="text-xs tabular-nums text-white ml-2"><%= number_with_precision(forecast_summary[:total_precipitation_mm], precision: 1) %> mm</span>
        </div>
        <div class="flex items-center justify-between rounded-md bg-zinc-800 px-2 py-1.5">
          <span class="text-xs text-zinc-400">Prob. máx.</span>
          <span class="text-xs tabular-nums text-white ml-2"><%= number_with_precision(forecast_summary[:max_probability], precision: 0) %>%</span>
        </div>
      </div>
    </div>

    <div class="px-4 py-3">
      <%= link_to admin_weather_path,
            class: "flex w-full items-center justify-center gap-2 rounded-lg border border-white/10 bg-zinc-800 px-4 py-2 text-xs font-medium text-zinc-400 transition-colors hover:border-sky-500 hover:text-sky-500",
            aria: { label: "Ver meteorologia completa" } do %>
        Ver meteorologia completa
        <svg class="h-3 w-3" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      <% end %>
    </div>
  </div>
</div>
