<% content_for(:title, "Naila — #{@river_basin.name}") %>

<% geojson_str = @river_basin.geometry ? RGeo::GeoJSON.encode(@river_basin.geometry).to_json : "" %>

<div class="mb-6 flex items-center gap-4">
  <%= catalyst_button_link "Bacias", href: admin_river_basins_path, variant: :plain do %>
    <svg data-slot="icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
    </svg>
    Voltar
  <% end %>
</div>

<div class="mb-8">
  <div class="mb-2 flex flex-wrap items-center gap-2">
    <%= risk_level_badge(@river_basin.current_risk_level) %>
    <%= catalyst_badge(@river_basin.active? ? "Ativa" : "Inativa", color: @river_basin.active? ? "green" : "zinc") %>
  </div>
  <%= catalyst_heading @river_basin.name, level: 1 %>
  <% if @river_basin.description.present? %>
    <%= catalyst_text @river_basin.description, class: "mt-1" %>
  <% end %>
</div>

<div class="grid gap-6 lg:grid-cols-3">
  <div class="lg:col-span-2 space-y-6">

    <%# Map — keep as-is (Stimulus controller) %>
    <div class="rounded-xl border border-white/10 bg-zinc-800/50">
      <div class="border-b border-white/10 px-6 py-4">
        <%= catalyst_subheading "Mapa da Bacia" %>
      </div>
      <div class="p-1">
        <div data-controller="admin--polygon-viewer"
             data-admin--polygon-viewer-geometry-value="<%= geojson_str %>"
             data-admin--polygon-viewer-risk-level-value="<%= @river_basin.current_risk_level %>"
             data-admin--polygon-viewer-target="canvas"
             class="h-[350px] w-full rounded-lg overflow-hidden"></div>
      </div>
    </div>

    <%# Details %>
    <div class="rounded-xl border border-white/10 bg-zinc-800/50" data-testid="basin-details">
      <div class="border-b border-white/10 px-6 py-4">
        <%= catalyst_subheading "Detalhes" %>
      </div>
      <%= catalyst_dl do %>
        <%= catalyst_dt "Área" %>
        <%= catalyst_dd @river_basin.area_km2 ? "#{number_with_precision(@river_basin.area_km2, precision: 1)} km²" : "—" %>

        <%= catalyst_dt "Rios" %>
        <%= catalyst_dd @river_basin.rivers.any? ? @river_basin.rivers.pluck(:name).join(", ") : "—" %>

        <%= catalyst_dt "Score Atual" %>
        <%= catalyst_dd @river_basin.current_risk_score ? number_to_percentage(@river_basin.current_risk_score * 100, precision: 1) : "—" %>

        <% if @river_basin.risk_factors.present? %>
          <%= catalyst_dt "Fatores de Risco" %>
          <%= catalyst_dd do %>
            <div class="grid grid-cols-2 gap-2">
              <% @river_basin.risk_factors.each do |factor, score| %>
                <div class="flex items-center justify-between rounded-md bg-zinc-800 px-2 py-1.5">
                  <span class="text-xs text-zinc-400 truncate"><%= factor.humanize %></span>
                  <span class="text-xs tabular-nums text-white ml-2"><%= number_to_percentage(score * 100, precision: 0) %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>

        <%= catalyst_dt "Última Avaliação" %>
        <%= catalyst_dd @river_basin.risk_updated_at ? l(@river_basin.risk_updated_at, format: :short) : "—" %>
      <% end %>
    </div>

    <%# Recent Assessments %>
    <% if @recent_assessments.any? %>
      <div class="rounded-xl border border-white/10 bg-zinc-800/50">
        <div class="flex items-center justify-between border-b border-white/10 px-6 py-4">
          <%= catalyst_subheading "Avaliações Recentes" %>
          <%= catalyst_text @recent_assessments.size.to_s %>
        </div>
        <%= catalyst_table(dense: true) do %>
          <%= catalyst_table_head do %>
            <tr>
              <%= catalyst_th "Data/Hora" %>
              <%= catalyst_th "Nível" %>
              <%= catalyst_th "Score" %>
            </tr>
          <% end %>
          <%= catalyst_table_body do %>
            <% @recent_assessments.each do |assessment| %>
              <%= catalyst_table_row do %>
                <%= catalyst_td assessment.assessed_at.strftime("%d/%m/%Y %H:%M"), class: "tabular-nums text-zinc-500 dark:text-zinc-400" %>
                <%= catalyst_td do %>
                  <%= tag.span(RiskHelper::ASSESSMENT_LEVEL_LABEL[assessment.risk_level],
                        class: "inline-flex rounded-full px-2 py-0.5 text-xs font-medium #{RiskHelper::ASSESSMENT_LEVEL_BADGE_CLASSES[assessment.risk_level]}") %>
                <% end %>
                <%= catalyst_td number_to_percentage(assessment.risk_score * 100, precision: 1), class: "tabular-nums" %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%# Active Alarms %>
    <% if @active_alarms.any? %>
      <div class="rounded-xl border border-white/10 bg-zinc-800/50">
        <div class="flex items-center justify-between border-b border-white/10 px-6 py-4">
          <%= catalyst_subheading "Alarmes Ativos" %>
          <%= catalyst_text @active_alarms.size.to_s %>
        </div>
        <div class="divide-y divide-white/10">
          <% @active_alarms.each do |alarm| %>
            <div class="flex items-center justify-between px-6 py-3">
              <div class="flex items-center gap-2">
                <%= severity_badge(alarm.current_severity) %>
                <%= catalyst_text_link alarm.name, href: admin_alarm_path(alarm) %>
              </div>
              <%= catalyst_text "#{time_ago_in_words(alarm.state_changed_at)} atrás" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>

  <div class="space-y-6">

    <div class="rounded-xl border border-white/10 bg-zinc-800/50">
      <div class="border-b border-white/10 px-6 py-4">
        <%= catalyst_subheading "Ações" %>
      </div>
      <div class="p-4 space-y-2">
        <% if policy(@river_basin).update? %>
          <%= catalyst_button_link "Editar Bacia", href: edit_admin_river_basin_path(@river_basin), variant: :outline, color: "zinc", class: "w-full justify-center" %>
        <% end %>
        <% if policy(@river_basin).destroy? %>
          <%= button_to admin_river_basin_path(@river_basin),
                method: :delete,
                class: "flex w-full items-center justify-center gap-2 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-2.5 text-sm font-medium text-red-400 hover:bg-red-500/20 transition-colors",
                form: { data: { turbo_confirm: "Tem certeza que deseja remover esta bacia hidrográfica?" } } do %>
            Remover Bacia
          <% end %>
        <% end %>
      </div>
    </div>

    <%= render "admin/river_basins/weather_context",
        forecast_summary: @forecast_summary,
        current_weather: @current_weather %>

    <div class="rounded-xl border border-white/10 bg-zinc-800/50">
      <div class="border-b border-white/10 px-6 py-4">
        <%= catalyst_subheading "Estatísticas" %>
      </div>
      <%= catalyst_dl do %>
        <%= catalyst_dt "Total de Avaliações" %><%= catalyst_dd @river_basin.risk_assessments.count.to_s %>
        <%= catalyst_dt "Total de Alarmes" %><%= catalyst_dd @river_basin.alarms.count.to_s %>
        <%= catalyst_dt "Criada em" %><%= catalyst_dd @river_basin.created_at.strftime("%d/%m/%Y") %>
      <% end %>
    </div>

  </div>
</div>
