<% content_for(:title, "Naila — Bacias Hidrográficas") %>

<%
  active_basins = @river_basins.select(&:active?)
  at_risk_basins = @river_basins.reject(&:risk_normal?)
%>

<%# ── Summary Cards ── %>
<div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
  <div class="rounded-xl border border-white/10 bg-zinc-900 p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-zinc-400">Total de Bacias</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-white" data-testid="summary-total-count"><%= @river_basins.size %></div>
  </div>
  <div class="rounded-xl border border-white/10 bg-zinc-900 p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-zinc-400">Bacias Ativas</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sky-500" data-testid="summary-active-count"><%= active_basins.size %></div>
  </div>
  <div class="rounded-xl border border-white/10 bg-zinc-900 p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-zinc-400">Bacias em Risco</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-risk-attention" data-testid="summary-at-risk-count"><%= at_risk_basins.size %></div>
  </div>
</div>

<%# ── River Basins Table ── %>
<div class="rounded-xl border border-white/10 bg-zinc-900">
  <div class="flex items-center justify-between border-b border-white/10 px-4 py-3">
    <h2 class="text-sm font-semibold text-white">Bacias Hidrográficas</h2>
    <% if policy(RiverBasin).create? %>
      <%= link_to new_admin_river_basin_path,
            class: "inline-flex items-center gap-1.5 rounded-lg bg-sky-500 px-3 py-2 text-xs font-medium text-white transition-colors hover:bg-sky-500/90" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Nova Bacia
      <% end %>
    <% end %>
  </div>

  <% if @river_basins.empty? %>
    <div class="px-4 py-8 text-center text-sm text-zinc-400">
      Nenhuma bacia hidrográfica cadastrada.
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-white/10">
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-400">Nível</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-400">Nome</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-400">Área (km²)</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-400">Score</th>
            <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-zinc-400">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          <% @river_basins.each do |basin| %>
            <tr class="hover:bg-zinc-800/50 transition-colors">
              <%# Nível de Risco %>
              <td class="px-4 py-3">
                <%= risk_level_badge(basin.current_risk_level) %>
              </td>

              <%# Nome %>
              <td class="px-4 py-3">
                <div class="text-sm font-medium text-white"><%= basin.name %></div>
                <% if basin.description.present? %>
                  <div class="text-xs text-zinc-400 truncate max-w-xs"><%= basin.description %></div>
                <% end %>
              </td>

              <%# Área %>
              <td class="px-4 py-3 text-sm tabular-nums text-zinc-400">
                <%= basin.area_km2 ? number_with_precision(basin.area_km2, precision: 1) : "—" %>
              </td>

              <%# Score %>
              <td class="px-4 py-3 text-sm tabular-nums text-zinc-400">
                <% if basin.current_risk_score %>
                  <%= number_to_percentage(basin.current_risk_score * 100, precision: 0) %>
                <% else %>
                  —
                <% end %>
              </td>

              <%# Ações %>
              <td class="px-4 py-3 text-right">
                <div class="inline-flex items-center gap-1">
                  <%= link_to admin_river_basin_path(basin),
                        class: "rounded-md p-1.5 text-zinc-400 hover:bg-zinc-800 hover:text-sky-500 transition-colors",
                        title: "Ver detalhes" do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                  <% end %>
                  <% if policy(basin).update? %>
                    <%= link_to edit_admin_river_basin_path(basin),
                          class: "rounded-md p-1.5 text-zinc-400 hover:bg-zinc-800 hover:text-sky-500 transition-colors",
                          title: "Editar" do %>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                      </svg>
                    <% end %>
                  <% end %>
                  <% if policy(basin).destroy? %>
                    <%= button_to admin_river_basin_path(basin),
                          method: :delete,
                          class: "rounded-md p-1.5 text-zinc-400 hover:bg-zinc-800 hover:text-risk-high transition-colors",
                          title: "Remover",
                          form: { data: { turbo_confirm: "Tem certeza que deseja remover esta bacia hidrográfica?" } } do %>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
