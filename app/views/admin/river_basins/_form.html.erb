<% existing_geojson = river_basin.geometry ? RGeo::GeoJSON.encode(river_basin.geometry).to_json : "" %>

<div class="rounded-xl border border-white/10 bg-zinc-900">
  <div class="border-b border-white/10 px-6 py-4">
    <h2 class="text-sm font-semibold text-white">Dados da Bacia Hidrográfica</h2>
  </div>

  <div class="p-6 space-y-5">
    <% if river_basin.errors.any? %>
      <div class="rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3">
        <p class="text-sm font-medium text-red-400">
          <%= river_basin.errors.count %> erro(s) impediu(iram) o salvamento:
        </p>
        <ul class="mt-2 list-disc pl-5 text-sm text-red-400/80">
          <% river_basin.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# Nome %>
    <div>
      <%= form.label :name, "Nome", class: "mb-1.5 block text-sm font-medium text-zinc-400" %>
      <%= form.text_field :name, required: true,
            class: "w-full rounded-lg border border-white/10 bg-zinc-800 px-3 py-2.5 text-white placeholder-zinc-400/50 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500",
            placeholder: "Ex: Bacia do Rio Belém" %>
    </div>

    <%# Área + Status %>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      <div>
        <%= form.label :area_km2, "Área (km²)", class: "mb-1.5 block text-sm font-medium text-zinc-400" %>
        <%= form.text_field :area_km2,
              class: "w-full rounded-lg border border-white/10 bg-zinc-800 px-3 py-2.5 tabular-nums text-white placeholder-zinc-400/50 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500",
              placeholder: "Ex: 87.8",
              inputmode: "decimal" %>
      </div>
      <div>
        <%= form.label :active, "Status", class: "mb-1.5 block text-sm font-medium text-zinc-400" %>
        <%= form.select :active,
              [["Ativa", true], ["Inativa", false]],
              {},
              class: "w-full rounded-lg border border-white/10 bg-zinc-800 px-3 py-2.5 text-white outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500" %>
      </div>
    </div>

    <%# Descrição %>
    <div>
      <%= form.label :description, "Descrição", class: "mb-1.5 block text-sm font-medium text-zinc-400" %>
      <%= form.text_area :description,
            rows: 3,
            class: "w-full rounded-lg border border-white/10 bg-zinc-800 px-3 py-2.5 text-white placeholder-zinc-400/50 outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 resize-none",
            placeholder: "Descrição opcional da bacia hidrográfica..." %>
    </div>

    <%# Geometria — Polygon Editor %>
    <div>
      <div class="mb-1.5 text-sm font-medium text-zinc-400">Geometria da Bacia</div>
      <div data-controller="admin--polygon-editor"
           data-admin--polygon-editor-geometry-value="<%= existing_geojson %>">
        <%# Map Canvas %>
        <div data-admin--polygon-editor-target="canvas"
             class="h-[400px] w-full rounded-t-lg border border-white/10 overflow-hidden"></div>

        <%# Toolbar %>
        <div class="flex items-center gap-2 rounded-b-lg border border-t-0 border-white/10 bg-zinc-800 px-3 py-2">
          <button type="button"
                  data-action="admin--polygon-editor#startDraw"
                  class="inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-medium text-zinc-400 hover:bg-white/10 hover:text-white transition-colors">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 8.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v8.25A2.25 2.25 0 0 0 6 16.5h2.25m8.25-8.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-7.5A2.25 2.25 0 0 1 8.25 18v-1.5m8.25-8.25h-6a2.25 2.25 0 0 0-2.25 2.25v6" />
            </svg>
            Desenhar Polígono
          </button>
          <button type="button"
                  data-action="admin--polygon-editor#clearPolygon"
                  class="inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-medium text-zinc-400 hover:bg-white/10 hover:text-risk-high transition-colors">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
            </svg>
            Limpar
          </button>
          <span class="ml-auto text-xs text-zinc-400" data-admin--polygon-editor-target="status"></span>
        </div>

        <%# Hidden field — synced by Stimulus controller %>
        <%= form.hidden_field :geometry_geojson,
              value: existing_geojson,
              data: { "admin--polygon-editor-target": "input" } %>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex items-center justify-end gap-3 border-t border-white/10 px-6 py-4">
    <%= link_to "Cancelar", admin_river_basins_path, class: "text-sm text-zinc-400 hover:text-white transition-colors" %>
    <%= form.submit river_basin.persisted? ? "Salvar" : "Criar Bacia",
          class: "rounded-lg bg-sky-500 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-sky-500/90 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-2 focus:ring-offset-zinc-950 cursor-pointer" %>
  </div>
</div>
