<% existing_geojson = river_basin.geometry ? RGeo::GeoJSON.encode(river_basin.geometry).to_json : "" %>

<div class="rounded-xl border border-white/10 bg-zinc-800/50 shadow-sm">
  <div class="border-b border-white/10 px-6 py-4">
    <%= catalyst_subheading(river_basin.persisted? ? "Editar Bacia Hidrográfica" : "Nova Bacia Hidrográfica") %>
  </div>

  <div class="p-6">
    <%= form.error_summary %>

    <%= form.field_group do %>
      <%= form.field do %>
        <%= form.label :name, "Nome" %>
        <%= form.text_field :name, required: true, placeholder: "Ex: Bacia do Rio Belém" %>
      <% end %>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
        <%= form.field do %>
          <%= form.label :area_km2, "Área (km²)" %>
          <%= form.text_field :area_km2, placeholder: "Ex: 87.8", inputmode: "decimal" %>
        <% end %>
        <%= form.field do %>
          <%= form.label :active, "Status" %>
          <%= form.select :active, [["Ativa", true], ["Inativa", false]] %>
        <% end %>
      </div>

      <%= form.field do %>
        <%= form.label :description, "Descrição" %>
        <%= form.text_area :description, rows: 3, placeholder: "Descrição opcional da bacia hidrográfica..." %>
      <% end %>

      <%# Geometria — Polygon Editor (keep raw HTML, Stimulus controller required) %>
      <div>
        <div class="mb-3 text-base/6 text-zinc-950 sm:text-sm/6 dark:text-white font-medium">Geometria da Bacia</div>
        <div data-controller="admin--polygon-editor"
             data-admin--polygon-editor-geometry-value="<%= existing_geojson %>">
          <div data-admin--polygon-editor-target="canvas"
               class="h-[400px] w-full rounded-t-lg border border-white/10 overflow-hidden"></div>

          <div class="flex items-center gap-2 rounded-b-lg border border-t-0 border-white/10 bg-zinc-800 px-3 py-2">
            <button type="button"
                    data-action="admin--polygon-editor#startDraw"
                    class="inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-medium text-zinc-400 hover:bg-white/10 hover:text-white transition-colors">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 8.25V6a2.25 2.25 0 0 0-2.25-2.25H6A2.25 2.25 0 0 0 3.75 6v8.25A2.25 2.25 0 0 0 6 16.5h2.25m8.25-8.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-7.5A2.25 2.25 0 0 1 8.25 18v-1.5m8.25-8.25h-6a2.25 2.25 0 0 0-2.25 2.25v6" />
              </svg>
              Desenhar Polígono
            </button>
            <button type="button"
                    data-action="admin--polygon-editor#clearPolygon"
                    class="inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-medium text-zinc-400 hover:bg-white/10 hover:text-risk-high transition-colors">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
              Limpar
            </button>
            <span class="ml-auto text-xs text-zinc-400" data-admin--polygon-editor-target="status"></span>
          </div>

          <%= form.hidden_field :geometry_geojson,
                value: existing_geojson,
                data: { "admin--polygon-editor-target": "input" } %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="flex items-center justify-end gap-3 border-t border-white/10 px-6 py-4">
    <%= catalyst_button_link "Cancelar", href: admin_river_basins_path, variant: :plain %>
    <%= form.submit river_basin.persisted? ? "Salvar Alterações" : "Criar Bacia" %>
  </div>
</div>
