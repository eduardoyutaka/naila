<% content_for(:title, "Naila — Usuários") %>

<%# ── Summary Cards ── %>
<div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
  <div class="rounded-xl border border-zinc-950/10 bg-white p-4 dark:border-white/10 dark:bg-zinc-900">
    <%= catalyst_text "Total de Usuários", class: "text-xs font-medium uppercase tracking-wider" %>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-zinc-950 dark:text-white"><%= @users.size %></div>
  </div>
  <div class="rounded-xl border border-zinc-950/10 bg-white p-4 dark:border-white/10 dark:bg-zinc-900">
    <%= catalyst_text "Usuários Ativos", class: "text-xs font-medium uppercase tracking-wider" %>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sensor-online"><%= @users.count(&:active?) %></div>
  </div>
  <div class="rounded-xl border border-zinc-950/10 bg-white p-4 dark:border-white/10 dark:bg-zinc-900">
    <%= catalyst_text "Recebem SMS", class: "text-xs font-medium uppercase tracking-wider" %>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sky-500"><%= @users.count(&:receives_sms_alerts?) %></div>
  </div>
</div>

<%# ── Users Table ── %>
<div class="rounded-xl border border-zinc-950/10 bg-white dark:border-white/10 dark:bg-zinc-900">
  <div class="flex items-center justify-between border-b border-zinc-950/10 px-4 py-3 dark:border-white/10">
    <%= catalyst_subheading "Usuários", class: "text-sm" %>
    <%= catalyst_button_link href: new_admin_user_path, color: "sky" do %>
      <svg class="h-4 w-4" data-slot="icon" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Novo Usuário
    <% end %>
  </div>

  <% if @users.empty? %>
    <div class="px-4 py-8 text-center">
      <%= catalyst_text "Nenhum usuário cadastrado." %>
    </div>
  <% else %>
    <%= catalyst_table(dense: true) do %>
      <%= catalyst_table_head do %>
        <tr>
          <%= catalyst_th "Nome" %>
          <%= catalyst_th "Email" %>
          <%= catalyst_th "Cargo" %>
          <%= catalyst_th "Departamento" %>
          <%= catalyst_th "Status" %>
          <%= catalyst_th "Ações", class: "text-right" %>
        </tr>
      <% end %>
      <%= catalyst_table_body do %>
        <% @users.each do |user| %>
          <%= catalyst_table_row do %>
            <%= catalyst_td do %>
              <div class="flex items-center gap-3">
                <%= catalyst_avatar initials: user.name.split.map(&:first).join.upcase[0..1], class: "size-8" %>
                <div>
                  <div class="text-sm font-medium text-zinc-950 dark:text-white"><%= user.name %></div>
                  <% if user.phone_number.present? %>
                    <div class="text-xs text-zinc-500 dark:text-zinc-400"><%= user.phone_number %></div>
                  <% end %>
                  <% last_session = user.sessions.max_by(&:created_at) %>
                  <% if last_session %>
                    <div class="text-xs text-zinc-500 dark:text-zinc-400">Último acesso: <%= time_ago_in_words(last_session.created_at) %> atrás</div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <%= catalyst_td user.email_address, class: "text-zinc-500 dark:text-zinc-400" %>

            <%= catalyst_td do %>
              <% role_color = case user.role
                              when "admin" then "purple"
                              when "coordinator" then "blue"
                              else "zinc"
                              end %>
              <% role_label = case user.role
                              when "admin" then "Administrador"
                              when "coordinator" then "Coordenador"
                              else "Operador"
                              end %>
              <%= catalyst_badge role_label, color: role_color %>
            <% end %>

            <%= catalyst_td (user.department || "—"), class: "text-zinc-500 dark:text-zinc-400" %>

            <%= catalyst_td do %>
              <div class="flex flex-col gap-1">
                <div class="flex items-center gap-1.5">
                  <span class="inline-block h-2 w-2 rounded-full <%= user.active? ? 'bg-sensor-online' : 'bg-sensor-offline' %>"></span>
                  <span class="text-xs text-zinc-500 dark:text-zinc-400"><%= user.active? ? "Ativo" : "Inativo" %></span>
                </div>
                <% if user.receives_sms_alerts? %>
                  <div class="flex items-center gap-1.5">
                    <svg class="h-3 w-3 text-zinc-500 dark:text-zinc-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3" />
                    </svg>
                    <span class="text-xs text-zinc-500 dark:text-zinc-400">SMS</span>
                  </div>
                <% end %>
              </div>
            <% end %>

            <%= catalyst_td class: "text-right" do %>
              <div class="flex items-center justify-end gap-2">
                <%= link_to edit_admin_user_path(user),
                      class: "rounded-md p-1.5 text-zinc-500 hover:bg-zinc-950/5 hover:text-sky-500 dark:text-zinc-400 dark:hover:bg-white/5 transition-colors",
                      title: "Editar" do %>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                  </svg>
                <% end %>
                <% unless user == current_user %>
                  <%= button_to admin_user_path(user), method: :delete,
                        class: "rounded-md p-1.5 text-zinc-500 hover:bg-red-500/10 hover:text-red-400 dark:text-zinc-400 transition-colors",
                        title: "Remover",
                        form: { data: { turbo_confirm: "Tem certeza que deseja remover #{user.name}?" } } do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
</div>
