<% content_for(:title, "Naila — Usuários") %>

<%# ── Summary Cards ── %>
<div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
  <div class="rounded-xl border border-white/10 bg-zinc-900 p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-zinc-400">Total de Usuários</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-white"><%= @users.size %></div>
  </div>
  <div class="rounded-xl border border-white/10 bg-zinc-900 p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-zinc-400">Usuários Ativos</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sensor-online"><%= @users.count(&:active?) %></div>
  </div>
  <div class="rounded-xl border border-white/10 bg-zinc-900 p-4">
    <div class="text-xs font-medium uppercase tracking-wider text-zinc-400">Recebem SMS</div>
    <div class="mt-2 text-3xl font-semibold tabular-nums text-sky-500"><%= @users.count(&:receives_sms_alerts?) %></div>
  </div>
</div>

<%# ── Users Table ── %>
<div class="rounded-xl border border-white/10 bg-zinc-900">
  <div class="flex items-center justify-between border-b border-white/10 px-4 py-3">
    <h2 class="text-sm font-semibold text-white">Usuários</h2>
    <%= link_to new_admin_user_path,
          class: "inline-flex items-center gap-1.5 rounded-lg bg-sky-500 px-3 py-2 text-xs font-medium text-white transition-colors hover:bg-sky-500/90" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Novo Usuário
    <% end %>
  </div>

  <% if @users.empty? %>
    <div class="px-4 py-8 text-center text-sm text-zinc-400">
      Nenhum usuário cadastrado.
    </div>
  <% else %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-white/10">
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-400">Nome</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-400">Email</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-400">Cargo</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-400">Departamento</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-400">Status</th>
            <th class="px-4 py-3 text-right text-xs font-medium uppercase tracking-wider text-zinc-400">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/10">
          <% @users.each do |user| %>
            <tr class="hover:bg-zinc-800/50 transition-colors">
              <%# Nome %>
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-zinc-800 text-xs font-medium text-white">
                    <%= user.name.split.map(&:first).join.upcase[0..1] %>
                  </div>
                  <div>
                    <div class="text-sm font-medium text-white"><%= user.name %></div>
                    <% if user.phone_number.present? %>
                      <div class="text-xs text-zinc-400"><%= user.phone_number %></div>
                    <% end %>
                    <% last_session = user.sessions.max_by(&:created_at) %>
                    <% if last_session %>
                      <div class="text-xs text-zinc-400">Último acesso: <%= time_ago_in_words(last_session.created_at) %> atrás</div>
                    <% end %>
                  </div>
                </div>
              </td>

              <%# Email %>
              <td class="px-4 py-3 text-sm text-zinc-400"><%= user.email_address %></td>

              <%# Cargo %>
              <td class="px-4 py-3">
                <% role_classes = case user.role
                                  when "admin" then "bg-purple-500/20 text-purple-400"
                                  when "coordinator" then "bg-blue-500/20 text-blue-400"
                                  else "bg-slate-500/20 text-slate-400"
                                  end %>
                <% role_label = case user.role
                                when "admin" then "Administrador"
                                when "coordinator" then "Coordenador"
                                else "Operador"
                                end %>
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium <%= role_classes %>">
                  <%= role_label %>
                </span>
              </td>

              <%# Departamento %>
              <td class="px-4 py-3 text-sm text-zinc-400"><%= user.department || "—" %></td>

              <%# Status %>
              <td class="px-4 py-3">
                <div class="flex flex-col gap-1">
                  <div class="flex items-center gap-1.5">
                    <span class="inline-block h-2 w-2 rounded-full <%= user.active? ? 'bg-sensor-online' : 'bg-sensor-offline' %>"></span>
                    <span class="text-xs text-zinc-400"><%= user.active? ? "Ativo" : "Inativo" %></span>
                  </div>
                  <% if user.receives_sms_alerts? %>
                    <div class="flex items-center gap-1.5">
                      <svg class="h-3 w-3 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3" />
                      </svg>
                      <span class="text-xs text-zinc-400">SMS</span>
                    </div>
                  <% end %>
                </div>
              </td>

              <%# Ações %>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center justify-end gap-2">
                  <%= link_to edit_admin_user_path(user),
                        class: "rounded-md p-1.5 text-zinc-400 hover:bg-zinc-800 hover:text-sky-500 transition-colors",
                        title: "Editar" do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                    </svg>
                  <% end %>
                  <% unless user == current_user %>
                    <%= button_to admin_user_path(user), method: :delete,
                          class: "rounded-md p-1.5 text-zinc-400 hover:bg-red-500/10 hover:text-red-400 transition-colors",
                          title: "Remover",
                          form: { data: { turbo_confirm: "Tem certeza que deseja remover #{user.name}?" } } do %>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
