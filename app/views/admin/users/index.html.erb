<% content_for(:title, "Naila — Usuários") %>

<%# ── Page Header ── %>
<div class="flex items-center justify-between mb-8">
  <%= catalyst_heading "Usuários", level: 1 %>
  <% if policy(User).create? %>
    <%= catalyst_button_link href: new_admin_user_path, color: "sky" do %>
      <svg class="h-4 w-4" data-slot="icon" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Novo Usuário
    <% end %>
  <% end %>
</div>

<%= turbo_frame_tag "users_list" do %>
  <%# ── Summary Cards ── %>
  <div class="mb-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="rounded-xl border border-white/10 bg-zinc-800/50 p-4">
      <p class="text-sm font-semibold uppercase tracking-wider text-zinc-300">Total de Usuários</p>
      <div class="mt-2 text-3xl font-semibold tabular-nums text-white"><%= @summary_counts[:total] %></div>
    </div>
    <div class="rounded-xl border border-white/10 bg-zinc-800/50 p-4">
      <p class="text-sm font-semibold uppercase tracking-wider text-zinc-300">Usuários Ativos</p>
      <div class="mt-2 text-3xl font-semibold tabular-nums text-sensor-online"><%= @summary_counts[:active] %></div>
    </div>
    <div class="rounded-xl border border-white/10 bg-zinc-800/50 p-4">
      <p class="text-sm font-semibold uppercase tracking-wider text-zinc-300">Recebem SMS</p>
      <div class="mt-2 text-3xl font-semibold tabular-nums text-sky-500"><%= @summary_counts[:sms] %></div>
    </div>
  </div>

  <%# ── Filter Bar ── %>
  <%= form_with url: admin_users_path, method: :get, scope: :q, data: { turbo_frame: "users_list" }, class: "mb-6 flex flex-wrap items-end gap-4" do |f| %>
    <div class="min-w-[200px] flex-1">
      <%= f.label :search, "Buscar", class: "block text-sm font-medium text-zinc-400 mb-1" %>
      <%= f.text_field :search, value: params.dig(:q, :search), placeholder: "Nome do usuário...",
            class: "w-full rounded-lg border border-white/10 bg-zinc-800 px-3 py-1.5 text-sm text-white placeholder-zinc-500 focus:border-sky-500 focus:ring-1 focus:ring-sky-500",
            data: { controller: "shared--auto-submit", action: "input->shared--auto-submit#submitDebounced" } %>
    </div>
    <div>
      <%= f.label :role, "Cargo", class: "block text-sm font-medium text-zinc-400 mb-1" %>
      <%= f.select :role, options_for_select([["Todos", ""], ["Administrador", "admin"], ["Coordenador", "coordinator"], ["Operador", "operator"]], params.dig(:q, :role)),
            {}, class: "rounded-lg border border-white/10 bg-zinc-800 px-3 py-1.5 text-sm text-white focus:border-sky-500 focus:ring-1 focus:ring-sky-500",
            data: { controller: "shared--auto-submit", action: "change->shared--auto-submit#submit" } %>
    </div>
    <div>
      <%= f.label :active, "Status", class: "block text-sm font-medium text-zinc-400 mb-1" %>
      <%= f.select :active, options_for_select([["Todos", ""], ["Ativo", "true"], ["Inativo", "false"]], params.dig(:q, :active)),
            {}, class: "rounded-lg border border-white/10 bg-zinc-800 px-3 py-1.5 text-sm text-white focus:border-sky-500 focus:ring-1 focus:ring-sky-500",
            data: { controller: "shared--auto-submit", action: "change->shared--auto-submit#submit" } %>
    </div>
  <% end %>

  <%# ── Users Table ── %>
  <% if @users.empty? %>
    <div class="rounded-xl border border-white/10 bg-zinc-800/50 px-4 py-8 text-center">
      <%= catalyst_text "Nenhum usuário encontrado." %>
      <% if params[:q].present? %>
        <div class="mt-4">
          <%= catalyst_button_link "Limpar filtros", href: admin_users_path, variant: :plain %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= catalyst_table(dense: true) do %>
      <%= catalyst_table_head do %>
        <tr>
          <%= catalyst_th "Nome" %>
          <%= catalyst_th "Email" %>
          <%= catalyst_th "Cargo" %>
          <%= catalyst_th "Departamento" %>
          <%= catalyst_th "Status" %>
          <%= catalyst_th "Ações", class: "text-right" %>
        </tr>
      <% end %>
      <%= catalyst_table_body do %>
        <% @users.each do |user| %>
          <%= catalyst_table_row do %>
            <%= catalyst_td do %>
              <div class="flex items-center gap-3">
                <%= catalyst_avatar initials: user.name.split.map(&:first).join.upcase[0..1], class: "size-8" %>
                <div>
                  <div class="text-sm font-medium text-zinc-950 dark:text-white"><%= user.name %></div>
                  <% if user.phone_number.present? %>
                    <div class="text-xs text-zinc-600 dark:text-zinc-300"><%= user.phone_number %></div>
                  <% end %>
                  <% last_session = user.sessions.max_by(&:created_at) %>
                  <% if last_session %>
                    <div class="text-xs text-zinc-600 dark:text-zinc-300">Último acesso: <%= time_ago_in_words(last_session.created_at) %> atrás</div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <%= catalyst_td user.email_address, class: "text-zinc-500 dark:text-zinc-300" %>

            <%= catalyst_td do %>
              <% role_color = case user.role
                              when "admin" then "purple"
                              when "coordinator" then "blue"
                              else "zinc"
                              end %>
              <% role_label = case user.role
                              when "admin" then "Administrador"
                              when "coordinator" then "Coordenador"
                              else "Operador"
                              end %>
              <%= catalyst_badge role_label, color: role_color %>
            <% end %>

            <%= catalyst_td (user.department || "—"), class: "text-zinc-500 dark:text-zinc-300" %>

            <%= catalyst_td do %>
              <div class="flex flex-col gap-1">
                <div class="flex items-center gap-1.5">
                  <span class="inline-block h-2 w-2 rounded-full <%= user.active? ? 'bg-sensor-online' : 'bg-sensor-offline' %>"></span>
                  <span class="text-xs text-zinc-600 dark:text-zinc-300"><%= user.active? ? "Ativo" : "Inativo" %></span>
                </div>
                <% if user.receives_sms_alerts? %>
                  <div class="flex items-center gap-1.5">
                    <svg class="h-3 w-3 text-zinc-500 dark:text-zinc-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3" />
                    </svg>
                    <span class="text-xs text-zinc-600 dark:text-zinc-300">SMS</span>
                  </div>
                <% end %>
              </div>
            <% end %>

            <%= catalyst_td class: "text-right" do %>
              <div class="flex items-center justify-end gap-2">
                <%= link_to edit_admin_user_path(user),
                      class: "rounded-md p-1.5 text-zinc-500 hover:bg-zinc-950/5 hover:text-sky-500 dark:text-zinc-400 dark:hover:bg-white/5 transition-colors",
                      title: "Editar",
                      data: { turbo_frame: "_top" },
                      aria: { label: "Editar #{user.name}" } do %>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                  </svg>
                <% end %>
                <% unless user == current_user %>
                  <%= button_to admin_user_path(user), method: :delete,
                        class: "rounded-md p-1.5 text-zinc-500 hover:bg-red-500/10 hover:text-red-400 dark:text-zinc-400 transition-colors",
                        title: "Remover",
                        aria: { label: "Remover #{user.name}" },
                        form: { data: { turbo_confirm: "Tem certeza que deseja remover #{user.name}?" } } do %>
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    <% end %>

    <%# ── Pagination ── %>
    <div class="mt-6">
      <%= catalyst_pagy_nav(@pagy) %>
    </div>
  <% end %>
<% end %>
