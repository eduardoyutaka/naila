<div class="rounded-xl border border-zinc-950/10 bg-white shadow-sm dark:border-white/10 dark:bg-zinc-900">
  <div class="border-b border-zinc-950/10 px-6 py-4 dark:border-white/10">
    <%= catalyst_subheading(user.persisted? ? "Editar Usuário" : "Novo Usuário") %>
  </div>

  <div class="p-6">
    <%= form.error_summary %>

    <%= form.field_group do %>
      <%= form.field do %>
        <%= form.label :name, "Nome" %>
        <%= form.text_field :name, required: true, placeholder: "Nome completo" %>
      <% end %>

      <%= form.field do %>
        <%= form.label :email_address, "Email" %>
        <%= form.email_field :email_address, required: true, placeholder: "usuario@exemplo.com" %>
      <% end %>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
        <%= form.field do %>
          <%= form.label :department, "Departamento" %>
          <%= form.text_field :department, placeholder: "Defesa Civil" %>
        <% end %>
        <%= form.field do %>
          <%= form.label :phone_number, "Telefone" %>
          <%= form.telephone_field :phone_number, placeholder: "+5541999000000" %>
        <% end %>
      </div>

      <%= form.field do %>
        <%= form.label :role, "Cargo" %>
        <%= form.select :role, [["Operador", "operator"], ["Coordenador", "coordinator"], ["Administrador", "admin"]] %>
      <% end %>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
        <%= form.field do %>
          <%= form.label :password, "Senha" %>
          <%= form.password_field :password, required: !user.persisted?, placeholder: "••••••••" %>
          <% if user.persisted? %>
            <%= form.description "Deixe em branco para manter a senha atual." %>
          <% end %>
        <% end %>
        <%= form.field do %>
          <%= form.label :password_confirmation, "Confirmar Senha" %>
          <%= form.password_field :password_confirmation, required: !user.persisted?, placeholder: "••••••••" %>
        <% end %>
      </div>

      <div class="flex flex-col gap-4 rounded-lg border border-zinc-950/10 bg-zinc-50 p-4 dark:border-white/10 dark:bg-zinc-800">
        <div class="flex items-center gap-3">
          <%= form.check_box :active, { disabled: user == current_user }, "true", "false" %>
          <%= form.label :active do %>
            Usuário ativo
            <% if user == current_user %>
              <span class="text-xs text-zinc-500 dark:text-zinc-400 ml-1">(você não pode desativar seu próprio usuário)</span>
            <% end %>
          <% end %>
        </div>
        <div class="flex items-start gap-3">
          <%= form.check_box :receives_sms_alerts, {}, "true", "false" %>
          <div>
            <%= form.label :receives_sms_alerts, "Recebe alertas por SMS" %>
            <p class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-400">Notificações por SMS para novos alarmes de nível alto ou emergência.</p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="flex items-center justify-end gap-3 border-t border-zinc-950/10 px-6 py-4 dark:border-white/10">
    <%= catalyst_button_link "Cancelar", href: admin_users_path, variant: :plain %>
    <%= form.submit user.persisted? ? "Salvar Alterações" : "Criar Usuário" %>
  </div>
</div>
