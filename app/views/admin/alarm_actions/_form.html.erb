<div class="rounded-xl border border-white/10 bg-zinc-800/50 shadow-sm">
  <div class="border-b border-white/10 px-6 py-4">
    <%= catalyst_subheading(alarm_action.persisted? ? "Editar Ação" : "Nova Ação") %>
  </div>

  <div class="p-6">
    <%= form.error_summary %>

    <%= form.hidden_field :action_type, value: "notification" %>

    <%= form.field_group do %>
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
        <%= form.field do %>
          <%= form.label :trigger_state, "Gatilho (Estado)" %>
          <%= form.select :trigger_state,
                [["Alarme", "alarm"], ["OK", "ok"], ["Dados Insuficientes", "insufficient_data"]] %>
        <% end %>
        <%= form.field do %>
          <%= form.label :min_severity, "Severidade Mínima" %>
          <%= form.select :min_severity,
                [["— Qualquer —", ""],
                 ["1 — Atenção", 1], ["2 — Alerta", 2], ["3 — Alto", 3], ["4 — Emergência", 4]] %>
          <%= form.description "Disparar somente se a severidade atual atingir este nível." %>
        <% end %>
      </div>

      <%= form.field do %>
        <%= form.label :enabled, "Status" %>
        <%= form.select :enabled, [["Ativada", true], ["Desativada", false]] %>
      <% end %>
    <% end %>
  </div>

  <div class="flex items-center justify-end gap-3 border-t border-white/10 px-6 py-4">
    <%= catalyst_button_link "Cancelar", href: admin_alarm_path(alarm_action.alarm || @alarm), variant: :plain %>
    <%= form.submit alarm_action.persisted? ? "Salvar Alterações" : "Criar Ação" %>
  </div>
</div>
