<div class="flex min-h-screen items-center justify-center bg-naila-bg p-4">
  <div class="w-full max-w-sm">
    <div class="mb-8 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-naila-accent">NAILA</h1>
      <p class="mt-2 text-sm text-naila-text-muted">Sistema de Monitoramento de Risco de Enchentes</p>
    </div>

    <div class="rounded-xl border border-naila-border bg-naila-surface p-6">
      <h2 class="mb-6 text-lg font-semibold text-naila-text">Entrar</h2>

      <%= form_with url: login_path, method: :post, class: "space-y-4" do |f| %>
        <div>
          <label for="email_address" class="mb-1.5 block text-sm font-medium text-naila-text-muted">Email</label>
          <input type="email" name="email_address" id="email_address" required autofocus
                 class="w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text placeholder-naila-text-muted/50 outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent"
                 placeholder="seu@email.com">
        </div>

        <div>
          <label for="password" class="mb-1.5 block text-sm font-medium text-naila-text-muted">Senha</label>
          <input type="password" name="password" id="password" required
                 class="w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text placeholder-naila-text-muted/50 outline-none focus:border-naila-accent focus:ring-1 focus:ring-naila-accent"
                 placeholder="••••••••">
        </div>

        <button type="submit"
                class="w-full rounded-lg bg-naila-accent px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-naila-accent/90 focus:outline-none focus:ring-2 focus:ring-naila-accent focus:ring-offset-2 focus:ring-offset-naila-bg">
          Entrar
        </button>
      <% end %>
    </div>
  </div>
</div>
