<div class="flex min-h-screen">

  <%# Left decorative panel — hidden on mobile %>
  <div class="relative hidden lg:flex lg:w-5/12 flex-col items-center justify-center overflow-hidden bg-naila-surface border-r border-naila-border"
       style="background-image: radial-gradient(circle, #334155 1px, transparent 1px); background-size: 28px 28px;">

    <%# Radar rings %>
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="absolute rounded-full border border-naila-accent/40"
           style="width: 160px; height: 160px; animation: ping-slow 3s ease-out infinite; animation-delay: 0s;"></div>
      <div class="absolute rounded-full border border-naila-accent/30"
           style="width: 160px; height: 160px; animation: ping-slow 3s ease-out infinite; animation-delay: 1s;"></div>
      <div class="absolute rounded-full border border-naila-accent/20"
           style="width: 160px; height: 160px; animation: ping-slow 3s ease-out infinite; animation-delay: 2s;"></div>
      <%# Center dot %>
      <div class="absolute w-3 h-3 rounded-full bg-naila-accent" style="box-shadow: 0 0 12px #3b82f6, 0 0 24px #3b82f680;"></div>
    </div>

    <%# Branding %>
    <div class="relative z-10 text-center px-10">
      <div class="mb-2 text-5xl font-bold tracking-tight text-naila-accent" style="text-shadow: 0 0 24px #3b82f680;">
        NAILA
      </div>
      <div class="text-sm font-medium text-naila-text-muted tracking-widest uppercase mb-2">
        Defesa Civil de Curitiba
      </div>
      <div class="mx-auto mb-10 h-px w-16 bg-naila-border"></div>
      <p class="text-sm text-naila-text-muted leading-relaxed max-w-xs">
        Monitoramento em tempo real de risco de enchentes para a Região Metropolitana de Curitiba.
      </p>
    </div>

    <%# Status indicators %>
    <div class="relative z-10 mt-12 flex flex-col gap-3 w-52">
      <div class="flex items-center justify-between rounded-lg border border-naila-border bg-naila-elevated/60 px-4 py-2.5">
        <span class="text-xs text-naila-text-muted">Sensores Online</span>
        <div class="flex items-center gap-1.5">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-sensor-online"></span>
          <span class="text-xs font-semibold text-naila-text tabular-nums"><%= @sensors_online %></span>
        </div>
      </div>
      <div class="flex items-center justify-between rounded-lg border border-naila-border bg-naila-elevated/60 px-4 py-2.5">
        <span class="text-xs text-naila-text-muted">Bacias Monitoradas</span>
        <div class="flex items-center gap-1.5">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-naila-accent"></span>
          <span class="text-xs font-semibold text-naila-text tabular-nums"><%= @river_basins_count %></span>
        </div>
      </div>
    </div>
  </div>

  <%# Right login panel %>
  <div class="flex flex-1 flex-col items-center justify-center px-6 py-12 lg:px-12">

    <%# Mobile-only logo %>
    <div class="mb-8 text-center lg:hidden">
      <div class="text-3xl font-bold tracking-tight text-naila-accent">NAILA</div>
      <p class="mt-1 text-xs text-naila-text-muted tracking-widest uppercase">Defesa Civil de Curitiba</p>
    </div>

    <div class="w-full max-w-sm animate-fade-in">

      <%# Header %>
      <div class="mb-8">
        <h1 class="text-2xl font-semibold text-naila-text">Acesso ao Painel</h1>
        <p class="mt-1.5 text-sm text-naila-text-muted">Sistema restrito a agentes autorizados</p>
      </div>

      <%# Flash messages %>
      <% if flash[:alert].present? %>
        <div class="mb-5 rounded-lg border border-risk-high/30 bg-risk-high/10 px-4 py-3 text-sm text-risk-high animate-fade-in">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 flex-shrink-0">
              <path fill-rule="evenodd" d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-8-5a.75.75 0 0 1 .75.75v4.5a.75.75 0 0 1-1.5 0v-4.5A.75.75 0 0 1 10 5Zm0 10a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd" />
            </svg>
            <%= flash[:alert] %>
          </div>
        </div>
      <% end %>

      <% if flash[:notice].present? %>
        <div class="mb-5 rounded-lg border border-green-500/30 bg-green-500/10 px-4 py-3 text-sm text-green-400 animate-fade-in">
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4 flex-shrink-0">
              <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
            </svg>
            <%= flash[:notice] %>
          </div>
        </div>
      <% end %>

      <%# Login form %>
      <%= form_with url: login_path, method: :post, class: "space-y-5" do |f| %>
        <div>
          <label for="email_address" class="mb-1.5 block text-sm font-medium text-naila-text-muted">Email</label>
          <input type="email" name="email_address" id="email_address" required autofocus
                 class="w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text placeholder-naila-text-muted/50 outline-none transition-colors focus:border-naila-accent focus:ring-1 focus:ring-naila-accent"
                 placeholder="seu@email.gov.br">
        </div>

        <div>
          <label for="password" class="mb-1.5 block text-sm font-medium text-naila-text-muted">Senha</label>
          <input type="password" name="password" id="password" required
                 class="w-full rounded-lg border border-naila-border bg-naila-elevated px-3 py-2.5 text-naila-text placeholder-naila-text-muted/50 outline-none transition-colors focus:border-naila-accent focus:ring-1 focus:ring-naila-accent"
                 placeholder="••••••••">
        </div>

        <button type="submit"
                class="w-full rounded-lg bg-naila-accent px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-naila-accent/90 focus:outline-none focus:ring-2 focus:ring-naila-accent focus:ring-offset-2 focus:ring-offset-naila-bg">
          Entrar
        </button>
      <% end %>

      <div class="mt-4 text-center">
        <%= link_to "Esqueceu sua senha?", new_password_reset_path,
              class: "text-xs text-naila-text-muted hover:text-naila-accent transition-colors" %>
      </div>

    </div>

    <%# Footer %>
    <p class="mt-12 text-xs text-naila-text-muted/50">
      &copy; 2026 Defesa Civil de Curitiba &mdash; Uso restrito
    </p>

  </div>
</div>
